let wybWallEl = null;

function startWybBackground() {
  stopWybBackground();
  const strip = document.getElementById('wyb-strip');
  const inner = document.getElementById('wyb-strip-inner');
  if (!strip || !inner) return;
  inner.innerHTML = '';
  // 随机打乱顺序，避免同套衣服集中
  const shuffled = [...WYB_PHOTOS].sort(() => Math.random() - 0.5);
  [...shuffled, ...shuffled].forEach((src, i) => {
    const img = document.createElement('img');
    img.src = src;
    img.className = 'wyb-photo';
    img.style.animationDelay = `-${(i * 0.15) % 4}s`;
    inner.appendChild(img);
  });
  strip.style.display = 'block';
  document.getElementById('wybUserFloat').classList.add('show');
  document.getElementById('normalUserBar').style.display = 'none';
  document.getElementById('recentDone').classList.add('show');
  renderRecentDone();
  const bubbles = document.getElementById('bubbles');
  if (bubbles) bubbles.style.opacity = '0.3';
}

function stopWybBackground() {
  const strip = document.getElementById('wyb-strip');
  if (strip) strip.style.display = 'none';
  const floatBar = document.getElementById('wybUserFloat');
  if (floatBar) floatBar.classList.remove('show');
  const normalBar = document.getElementById('normalUserBar');
  if (normalBar) normalBar.style.display = '';
  const recentDone = document.getElementById('recentDone');
  if (recentDone) recentDone.classList.remove('show');
  const bubbles = document.getElementById('bubbles');
  if (bubbles) bubbles.style.opacity = '1';
}

function renderRecentDone() {
  const d = get();
  const el = document.getElementById('recentDoneList');
  if (!el) return;
  const done = d.todos.filter(x=>x.done)
    .sort((a,b)=>(b.createdAt||0)-(a.createdAt||0))
    .slice(0, 4);
  if (!done.length) { el.innerHTML = '<div style="font-size:12px;color:#bbb;padding:4px">暂无完成记录</div>'; return; }
  el.innerHTML = done.map(t=>`
    <div class="recent-done-item">
      <span class="chk">✓</span>
      <span class="txt">${esc(t.text)}</span>
      <span class="tm">${t.doneTime||''}</span>
    </div>`).join('');
}

// ── 主题按钮事件 ──
document.querySelectorAll('.theme-btn').forEach(btn => {
  btn.addEventListener('click', ()=>{ if(!isReadonly) applyTheme(btn.dataset.theme); });
});

// ── 启动 ──
chooseIdentity();

// 聊天发送事件绑定（避免 onclick 在某些环境下失效）
document.addEventListener('DOMContentLoaded', () => {
  setMobileHomeMode(true);
  updateMobileNav('home');
  bindBackupImportInput();
  const btn = document.getElementById('chatSendBtn');
  const inp = document.getElementById('chatInput');
  const emojiBtn = document.getElementById('emojiToggleBtn');
  if (btn) btn.addEventListener('click', () => window.sendMessage());
  if (inp) {
    inp.addEventListener('keydown', e => {
      if(e.key==='Enter' && !e.shiftKey) {
        e.preventDefault();
        window.sendMessage();
      }
    });
    inp.addEventListener('focus', () => {
      document.body.classList.add('mobile-chat-focused');
      setTimeout(() => {
        updateChatViewport();
        const el = document.getElementById('chatMessages');
        el.scrollTop = el.scrollHeight;
      }, 120);
    });
    inp.addEventListener('blur', () => { document.body.classList.remove('mobile-chat-focused'); settleChatViewport(); });
  }
  buildEmojiPanel();
  if (emojiBtn) {
    emojiBtn.addEventListener('click', () => {
      const panel = document.getElementById('emojiPanel');
      panel.classList.toggle('show');
      requestAnimationFrame(updateChatViewport);
    });
  }
  window.onSummaryRangeChange?.();
  updateChatUnreadBadge();
  window.addEventListener('resize', updateChatViewport);
  window.visualViewport?.addEventListener('resize', updateChatViewport);
  window.visualViewport?.addEventListener('scroll', updateChatViewport);
  window.addEventListener('orientationchange', settleChatViewport);
  document.addEventListener('visibilitychange', () => {
    if (!document.hidden && document.getElementById('tab-chat')?.classList.contains('active')) {
      clearChatUnread();
      settleChatViewport();
    }
  });
  if (location.hash === '#chat') setTimeout(() => window.openChatPage(), 150);
});
</script>
