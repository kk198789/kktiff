  </div>
</div>


<!-- 5.0：手机端五键导航与记录菜单 -->
<div class="mobile-quick-overlay" id="mobileQuickOverlay" onclick="closeMobileQuickMenu()"></div>
<div class="mobile-quick-sheet" id="mobileQuickSheet" aria-hidden="true">
  <div class="mobile-quick-title">快速记录</div>
  <div class="mobile-quick-grid compact">
    <button class="mobile-quick-item primary" type="button" onclick="mobileQuickAddTodo(); closeMobileQuickMenu();"><span class="quick-ico">＋</span>添加待办</button>
    <button class="mobile-quick-item" type="button" onclick="mobileQuickMemo(); closeMobileQuickMenu();"><span class="quick-ico">🌙</span>快速备忘</button>
    <button class="mobile-quick-item" type="button" onclick="mobileQuickLogDone(); closeMobileQuickMenu();"><span class="quick-ico">✅</span>补记完成</button>
  </div>
</div>
<nav class="mobile-bottom-nav" id="mobileBottomNav" aria-label="手机底部导航">
  <button class="mobile-nav-btn active" type="button" data-mobile-nav="home" onclick="mobileGoHome()"><span class="ico">🏠</span><span>今日</span></button>
  <button class="mobile-nav-btn" type="button" data-mobile-nav="todo" onclick="switchTab('todo')"><span class="ico">✅</span><span>待办</span></button>
  <button class="mobile-nav-plus" type="button" aria-label="快速记录" onclick="toggleMobileQuickMenu()">＋</button>
  <button class="mobile-nav-btn" type="button" data-mobile-nav="summary" onclick="switchTab('summary')"><span class="ico">📊</span><span>总结</span></button>
  <button class="mobile-nav-btn" type="button" data-mobile-nav="chat" onclick="openChatPage()"><span class="ico">💌</span><span id="mobileLineLabel">专线</span><span class="mobile-line-badge" id="mobileChatUnreadBadge" hidden>0</span></button>
</nav>
<button class="mobile-settings-fab" type="button" onclick="switchTab('settings')" aria-label="设置">⚙️</button>


<script>
// Mac/Codex 预览环境如果阻止 Firebase 模块加载，至少不要一直像卡死一样显示“连接中”。
window.addEventListener('error', function(e) {
  if (String(e.message || '').includes('module') || String(e.filename || '').includes('firebase')) {
    const txt = document.querySelector('#loadingOverlay .loading-text');
    if (txt) txt.textContent = 'Firebase 模块加载失败，请用浏览器或本地服务器打开';
  }
}, true);
setTimeout(function() {
  const overlay = document.getElementById('loadingOverlay');
  const txt = document.querySelector('#loadingOverlay .loading-text');
  if (overlay && overlay.style.display !== 'none' && txt && txt.textContent === '连接中...') {
    txt.textContent = '连接较慢：请检查网络 / Firebase / 是否用本地服务器打开';
  }
}, 9000);
</script>


<script>
// ── 6.0 PWA App 化：安装提示与 Service Worker 注册 ──
let deferredPwaPrompt = null;

function isStandaloneMode() {
  return window.matchMedia?.('(display-mode: standalone)')?.matches || window.navigator.standalone === true;
}

function setPwaStatus(text) {
  const el = document.getElementById('pwaStatus');
  if (el) el.textContent = 'PWA 状态：' + text;
}

window.addEventListener('beforeinstallprompt', event => {
  event.preventDefault();
  deferredPwaPrompt = event;
  setPwaStatus('可以安装到主屏幕');
  const btn = document.getElementById('installPwaBtn');
  if (btn) btn.disabled = false;
});

window.installPwa = async function() {
  if (isStandaloneMode()) {
    alert('已经是 App 模式打开了。');
    return;
  }
  if (deferredPwaPrompt) {
    deferredPwaPrompt.prompt();
    const choice = await deferredPwaPrompt.userChoice.catch(() => null);
    deferredPwaPrompt = null;
    setPwaStatus(choice?.outcome === 'accepted' ? '已发送安装请求' : '已取消安装');
    return;
  }
  showPwaHelp();
};

window.showPwaHelp = function() {
  const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
  const isSecure = location.protocol === 'https:' || location.hostname === 'localhost' || location.hostname === '127.0.0.1';
  const lines = [];
  if (isIOS) {
    lines.push('iPhone 安装方式：');
    lines.push('1. 用 Safari 打开这个页面');
    lines.push('2. 点底部“分享”按钮');
    lines.push('3. 选择“添加到主屏幕”');
    lines.push('4. 名称可设为“深空工作台”');
  } else {
    lines.push('Android / 桌面浏览器安装方式：');
    lines.push('1. 用 Chrome / Edge 打开页面');
    lines.push('2. 地址栏或菜单中选择“安装应用 / 添加到主屏幕”');
  }
  if (!isSecure) {
    lines.push('');
    lines.push('提示：当前是局域网 http 地址，可能只能当普通主屏幕快捷方式；完整 PWA 缓存能力建议部署到 HTTPS，或在 Mac 本机用 localhost 测试。');
  }
  alert(lines.join('\\n'));
};

(function registerPwaServiceWorker(){
  const isSecure = location.protocol === 'https:' || location.hostname === 'localhost' || location.hostname === '127.0.0.1';
  if (isStandaloneMode()) setPwaStatus('正在以 App 模式运行');
  if (!('serviceWorker' in navigator)) {
    setPwaStatus('当前浏览器不支持 Service Worker');
    return;
  }
  if (!isSecure) {
    setPwaStatus('当前地址不是 HTTPS / localhost，Service Worker 暂不注册');
    return;
  }
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('./service-worker.js', { scope: './' })
      .then(reg => {
        reg.update?.();
        setPwaStatus(isStandaloneMode() ? 'App 模式运行中' : 'Service Worker 已注册，可添加到主屏幕');
      })
      .catch(err => {
        console.warn('Service Worker 注册失败', err);
        setPwaStatus('Service Worker 注册失败，页面仍可正常使用');
      });
  });
})();
</script>

<!-- Firebase SDK -->
<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
import { getFirestore, doc, onSnapshot, setDoc, deleteDoc, getDoc,
  collection, addDoc, query, orderBy, limit, writeBatch }
  from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js';

// ── Firebase 初始化 ──
const firebaseConfig = {
  apiKey: "AIzaSyCwChifMIU5WH0HFNqXWkQs3Tcx4bxSGho",
  authDomain: "kk-tiff.firebaseapp.com",
  projectId: "kk-tiff",
  storageBucket: "kk-tiff.firebasestorage.app",
  messagingSenderId: "176147798745",
  appId: "1:176147798745:web:c93ab8458377c63f43bcc8"
};
const app = initializeApp(firebaseConfig);
const db  = getFirestore(app);

// ── 用户配置 ──
// 每次打开页面时选择自己的身份（存在 localStorage 里，下次自动恢复）
const USERS = { kk: 'KK', tiffany: 'Tiffany' };
const LOCAL_IDENTITY_KEY = 'wk_identity';

// 当前身份 & 当前浏览的用户
let myIdentity   = localStorage.getItem(LOCAL_IDENTITY_KEY) || null;
let viewingUser  = null;   // 正在查看哪个用户的数据
let isReadonly   = false;  // 是否只读模式

// 两个用户的数据缓存（实时监听更新）
const cache = {
  kk:      { todos:[], memos:[], logs:[], settings:{ enabled:true, hour:17, min:30 }, theme:'space' },
  tiffany: { todos:[], memos:[], logs:[], settings:{ enabled:true, hour:17, min:30 }, theme:'space' }
};
// Firestore 监听取消函数
const unsubscribers = {};

// ── 主题配置 ──
const themes = {
  space:   { name:'深空工作台', bg:['#f3f8fd','#edf5fc','#e7f1fa','#f8fbfe','#eef6fc'], accent:'#2368ad', accent2:'#1c568f', text:'#172536', muted:'#607185', border:'#ccdeee', surface2:'#e3eef9', accentSoft:'#dbeafb', secondary:'#d07a29', secondarySoft:'#fae8d6', title:'🚀 深空工作台', subtitle:'保持航向，处理今天真正重要的事', icons:['🚀','🛰️','🌙','✨'], statDone:'🚀 今日完成', statPending:'🛸 待办事项', statMemo:'⭐ 备忘数量', tabTodo:'🛸 待办事项', tabMemo:'🌙 快速备忘', tabLog:'🪐 工作日志', tabCal:'🌌 记录日历', tabSettings:'🔭 设置', btnAdd:'🚀 添加', btnClear:'🛰️ 清除已完成', btnMemo:'🌟 记下', calStar:'🚀' },
  dino:    { name:'远古森林', bg:['#f4faf8','#edf8f4','#e5f2ed','#f9fcfb','#edf7f3'], accent:'#087a67', accent2:'#066353', text:'#172522', muted:'#61716c', border:'#cfe2dc', surface2:'#e4f1ed', accentSoft:'#d8eee7', secondary:'#c35f35', secondarySoft:'#f7e2d8', title:'🦕 远古森林', subtitle:'稳稳向前，把复杂的事情逐步完成', icons:['🦕','🌿','🌳','🍃'], statDone:'🥚 今日孵化', statPending:'🦕 待办事项', statMemo:'🌿 备忘叶子', tabTodo:'🦕 待办事项', tabMemo:'🌿 快速备忘', tabLog:'🌳 工作日志', tabCal:'🌴 记录日历', tabSettings:'🦎 设置', btnAdd:'🦕 添加', btnClear:'🌱 清除已完成', btnMemo:'🌿 记下', calStar:'🦕' },
  star:    { name:'星轨工作台', bg:['#f5f7fd','#eef2fb','#e7edf9','#fafbfe','#f0f3fb'], accent:'#3d5fa9', accent2:'#304c8b', text:'#1c2638', muted:'#667087', border:'#d2daed', surface2:'#e7ecf7', accentSoft:'#dfe6f7', secondary:'#b8801f', secondarySoft:'#f7ecd2', title:'⭐ 星轨工作台', subtitle:'让每一次完成都留下清晰轨迹', icons:['⭐','🌙','✨','🪐'], statDone:'⭐ 今日闪耀', statPending:'🌟 待办星星', statMemo:'💫 备忘光芒', tabTodo:'⭐ 待办事项', tabMemo:'✨ 快速备忘', tabLog:'🌟 工作日志', tabCal:'🌠 记录日历', tabSettings:'🔮 设置', btnAdd:'⭐ 添加', btnClear:'✨ 清除已完成', btnMemo:'🌟 记下', calStar:'⭐' },
  cat:     { name:'夜猫工作室', bg:['#fcf6f8','#faf0f3','#f5e8ed','#fefafb','#f9eef2'], accent:'#a63859', accent2:'#862d48', text:'#2b2025', muted:'#75666d', border:'#ead6dd', surface2:'#f4e7eb', accentSoft:'#f4dce4', secondary:'#267c78', secondarySoft:'#d9eeec', title:'🐱 夜猫工作室', subtitle:'安静专注，完成手边这一件事', icons:['🐱','🌙','🐾','✨'], statDone:'🐱 今日完成', statPending:'🌙 待办事项', statMemo:'🐾 备忘事项', tabTodo:'🐱 待办事项', tabMemo:'🌙 快速备忘', tabLog:'🐾 工作日志', tabCal:'✨ 记录日历', tabSettings:'🐈 设置', btnAdd:'🐱 添加', btnClear:'🌙 清除已完成', btnMemo:'🐾 记下', calStar:'🐱' },
  wyb:     { name:'王一博❤️', bg:['#1a1a2e','#16213e','#0f3460','#533483','#e94560'], accent:'#e94560', accent2:'#533483', text:'#374151', muted:'#6b7280', border:'rgba(245,87,108,0.2)', surface2:'#f3f4f6', accentSoft:'rgba(245,87,108,0.1)', secondary:'#533483', secondarySoft:'rgba(83,52,131,0.1)', title:'🏍️ 一博工作台', subtitle:'💫 无所畏惧，乘风破浪，今天也要加油！✨', icons:['⚡','🏍️','🎵','🎤','🌙','💫','🔥','🖤','👑','✨'], statDone:'⚡ 今日完成', statPending:'🔥 待办事项', statMemo:'🌙 备忘事项', tabTodo:'🔥 待办事项', tabMemo:'🌙 快速备忘', tabLog:'⚡ 工作日志', tabCal:'🌙 记录日历', tabSettings:'👑 设置', btnAdd:'⚡ 添加', btnClear:'🖤 清除已完成', btnMemo:'🌙 记下', calStar:'⚡' },
};

const themeLayouts = {
  space:'achievement', star:'achievement',
  cat:'focus',
  wyb:'support',
  dino:'standard'
};

const themeAliases = {
  giraffe:'dino', zoo:'dino', fox:'dino',
  bunny:'cat', penguin:'space', ocean:'space'
};

let currentTheme = 'space';
let focusTaskOffset = 0;
let currentFocusTaskId = null;

// ── Firestore 子集合路径 ──
function userCol(userId, col) { return collection(db, 'users', userId, col); }
function userDocRef(userId, col, id) { return doc(db, 'users', userId, col, id); }
function metaDoc(userId, key) { return doc(db, 'users', userId, 'meta', key); }

// ── 写入工具 ──
async function cloudSet(ref, data) {
  try { await setDoc(ref, data); setSyncStatus(true); }
  catch(e) { console.error('写入失败', e); setSyncStatus(false); setSyncMessage('写入失败：' + (e.code || e.message || '未知错误'), false); }
}
async function cloudAdd(userId, col, data) {
  try { const r = await addDoc(userCol(userId, col), data); setSyncStatus(true); return r.id; }
  catch(e) { console.error('添加失败', e); setSyncStatus(false); setSyncMessage('添加失败：' + (e.code || e.message || '未知错误'), false); return null; }
}
async function cloudDelete(ref) {
  try { await deleteDoc(ref); setSyncStatus(true); }
  catch(e) { console.error('删除失败', e); setSyncStatus(false); setSyncMessage('删除失败：' + (e.code || e.message || '未知错误'), false); }
}

// ── 旧 logs 一次性迁移 ──
async function migrateOldLogs(userId) {
  const migKey = 'wk_logs_migrated_' + userId;
  if (localStorage.getItem(migKey)) return;
  try {
    const oldDoc = await getDoc(doc(db, 'users', userId));
    if (!oldDoc.exists()) { localStorage.setItem(migKey, '1'); return; }
    const old = oldDoc.data();
    if (!Array.isArray(old.logs) || old.logs.length === 0) {
      localStorage.setItem(migKey, '1'); return;
    }
    const batch = writeBatch(db);
    old.logs.forEach(l => {
      const ref = doc(userCol(userId, 'logs'));
      batch.set(ref, { ...l, createdAt: l.createdAt || Date.now() });
    });
    await batch.commit();
    localStorage.setItem(migKey, '1');
    console.log(userId, 'logs 迁移完成，共', old.logs.length, '条');
  } catch(e) {
    console.error('logs 迁移失败', e);
  }
}

function hideLoading() {
  document.getElementById('loadingOverlay').style.display = 'none';
}

// ── 订阅用户全部数据（子集合方式）──
function subscribeUser(userId) {
  if (unsubscribers[userId]) return;

  // 超时兜底：8秒后关闭加载遮罩
  const timeoutId = setTimeout(() => {
    setSyncStatus(false); hideLoading();
    if (viewingUser === userId) refreshAll();
  }, 8000);

  let loaded = { todos:false, memos:false, logs:false, settings:false };
  function checkAllLoaded() {
    if (Object.values(loaded).every(Boolean)) {
      clearTimeout(timeoutId); hideLoading();
      if (viewingUser === userId) refreshAll();
    }
  }

  // todos
  const u1 = onSnapshot(userCol(userId,'todos'), snap => {
    setSyncStatus(true);
    cache[userId].todos = snap.docs.map(d => ({ ...d.data(), _docId: d.id }))
      .sort((a,b) => (a.createdAt||0) - (b.createdAt||0));
    loaded.todos = true; checkAllLoaded();
    if (viewingUser===userId) { renderTodos(); updateStats(); if(currentTheme==='wyb') renderRecentDone(); }
  }, err => { setSyncStatus(false); loaded.todos=true; checkAllLoaded();
    if (err.code==='permission-denied') alert('⚠️ Firestore 权限被拒绝，请检查 Rules。'); });

  // memos
  const u2 = onSnapshot(userCol(userId,'memos'), snap => {
    setSyncStatus(true);
    cache[userId].memos = snap.docs.map(d => ({ ...d.data(), _docId: d.id }))
      .sort((a,b) => (a.createdAt||0) - (b.createdAt||0));
    loaded.memos = true; checkAllLoaded();
    if (viewingUser===userId) { renderMemos(); updateStats(); }
  }, err => { setSyncStatus(false); loaded.memos=true; checkAllLoaded(); });

  // logs
  const u3 = onSnapshot(userCol(userId,'logs'), snap => {
    setSyncStatus(true);
    cache[userId].logs = snap.docs.map(d => ({ ...d.data(), _docId: d.id }))
      .sort((a,b) => (a.createdAt||0) - (b.createdAt||0));
    loaded.logs = true; checkAllLoaded();
    if (viewingUser===userId) { renderLog(); renderCal(); updateStats(); }
  }, err => { setSyncStatus(false); loaded.logs=true; checkAllLoaded(); });

  // settings
  const u4 = onSnapshot(metaDoc(userId,'settings'), snap => {
    if (snap.exists()) cache[userId].settings = snap.data();
    loaded.settings = true; checkAllLoaded();
    if (viewingUser===userId && !isReadonly) initSettings();
  }, err => { setSyncStatus(false); loaded.settings=true; checkAllLoaded(); });

  // theme
  const u5 = onSnapshot(metaDoc(userId,'theme'), snap => {
    if (snap.exists()) {
      cache[userId].theme = snap.data().name || 'space';
      if (viewingUser===userId) applyTheme(cache[userId].theme, false);
    }
  }, err => { /* theme 读失败不影响主流程 */ });

  unsubscribers[userId] = () => { u1(); u2(); u3(); u4(); u5(); };
}


function setSyncStatus(online) {
  const dot = document.getElementById('syncDot');
  if (dot) {
    dot.classList.toggle('offline', !online);
    dot.title = online ? '实时同步中' : '连接断开，请检查网络';
  }
  const fdot = document.getElementById('wybSyncDot');
  if (fdot) fdot.style.background = online ? '#10b981' : '#ef4444';
  setSyncMessage(online ? '实时同步正常' : '连接断开，请检查网络 / Firebase 权限', online);
}

// ── 获取当前查看用户的数据 ──
function get() { return cache[viewingUser]; }

// ── set() 已废弃，数据操作直接调用 cloudAdd/cloudSet/cloudDelete ──

// ── 身份选择 ──
function chooseIdentity() {
  // 如果已有身份记录，自动恢复
  if (myIdentity && USERS[myIdentity]) {
    initWithIdentity(myIdentity);
    return;
  }
  // 弹出选择
  const choice = confirm('你是 KK 吗？\n\n点「确定」= KK\n点「取消」= Tiffany');
  myIdentity = choice ? 'kk' : 'tiffany';
  localStorage.setItem(LOCAL_IDENTITY_KEY, myIdentity);
  initWithIdentity(myIdentity);
}

function initWithIdentity(userId) {
  viewingUser = userId;
  isReadonly  = false;
  updateUserBar();
  // 订阅两个用户的实时数据
  // 迁移旧 logs 数据（一次性）
  migrateOldLogs('kk');
  migrateOldLogs('tiffany');
  subscribeUser('kk');
  subscribeUser('tiffany');
  subscribeChat();
  updateLineLabels();
  setMobileHomeMode(true);
  updateMobileNav('home');
  // 主题应用（优先用 cache，否则用 localStorage 备份）
  const localTheme = localStorage.getItem('wk_theme_' + userId);
  if (localTheme && (themes[localTheme] || themeAliases[localTheme])) applyTheme(localTheme, false);
  else makeBubbles();
  initSettings();
  checkReminderOnLoad();
  setInterval(checkReminder, 60000);
}

// ── 切换查看用户 ──
window.switchUser = function(userId) {
  if (viewingUser === userId) return;
  viewingUser = userId;
  isReadonly  = (userId !== myIdentity);
  updateUserBar();
  updateReadonlyUI();
  refreshAll();
};

function updateUserBar() {
  document.getElementById('btnKK').classList.toggle('active', viewingUser === 'kk');
  document.getElementById('btnTiffany').classList.toggle('active', viewingUser === 'tiffany');
  // 同步浮动标签
  const fkk = document.getElementById('wybBtnKK');
  const ftiff = document.getElementById('wybBtnTiffany');
  if (fkk) fkk.classList.toggle('active', viewingUser === 'kk');
  if (ftiff) ftiff.classList.toggle('active', viewingUser === 'tiffany');
  updateLineLabels();
}


function updateReadonlyUI() {
  const banner = document.getElementById('readonlyBanner');
  banner.classList.toggle('show', isReadonly);
  // 输入控件禁用/启用
  ['todoInput','todoCategory','todoDueDate','memoInput','btnAdd','btnClear','btnMemo'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.disabled = isReadonly;
  });
  // 主题按钮在只读时隐藏（不允许改对方主题）
  document.querySelector('.theme-selector').style.opacity = isReadonly ? '0.4' : '1';
  document.querySelector('.theme-selector').style.pointerEvents = isReadonly ? 'none' : '';
  // 设置 tab 隐藏
  document.getElementById('tabSettings').style.opacity = isReadonly ? '0.4' : '1';
  document.getElementById('tabSettings').style.pointerEvents = isReadonly ? 'none' : '';
}

function refreshAll() {
  const d = get();
  // 应用被查看用户的主题
  const theme = d.theme || 'space';
  applyTheme(theme, false);
  renderTodos();
  renderMemos();
  renderLog();
  renderCal();
  updateStats();
  const t = themes[currentTheme];
  if (t) {
    document.getElementById('mainTitle').textContent    = (isReadonly ? '👀 ' : '') + t.title;
    document.getElementById('mainSubtitle').textContent = isReadonly
      ? `正在查看 ${USERS[viewingUser]} 的工作台`
      : t.subtitle;
  }
}

// ── 主题 ──
async function applyTheme(themeName, save = true) {
  themeName = themeAliases[themeName] || themeName;
  const t = themes[themeName];
  if (!t) return;
  currentTheme = themeName;
  const layout = themeLayouts[themeName] || 'standard';
  document.body.dataset.theme = themeName;
  document.body.classList.toggle('theme-layout-wyb', layout === 'support');
  document.body.classList.toggle('theme-layout-cosmic', layout === 'achievement');
  document.body.classList.toggle('theme-layout-star', themeName === 'star');
  document.body.classList.toggle('theme-layout-focus', layout === 'focus');
  document.body.classList.toggle('theme-layout-cat', themeName === 'cat');
  focusTaskOffset = 0;
  document.documentElement.style.setProperty('--bg1', t.bg[0]);
  document.documentElement.style.setProperty('--bg2', t.bg[1]);
  document.documentElement.style.setProperty('--bg3', t.bg[2]);
  document.documentElement.style.setProperty('--bg4', t.bg[3]);
  document.documentElement.style.setProperty('--bg5', t.bg[4]);
  document.documentElement.style.setProperty('--accent',  t.accent);
  document.documentElement.style.setProperty('--accent2', t.accent2);
  document.documentElement.style.setProperty('--text', t.text || '#374151');
  document.documentElement.style.setProperty('--muted', t.muted || '#6b7280');
  document.documentElement.style.setProperty('--theme-border', t.border || '#d7dde1');
  document.documentElement.style.setProperty('--surface-2', t.surface2 || '#edf1f3');
  document.documentElement.style.setProperty('--accent-soft', t.accentSoft || 'rgba(15,23,42,0.07)');
  document.documentElement.style.setProperty('--secondary', t.secondary || t.accent2);
  document.documentElement.style.setProperty('--secondary-soft', t.secondarySoft || 'rgba(15,23,42,0.07)');
  document.getElementById('mainTitle').textContent    = (isReadonly ? '👀 ' : '') + t.title;
  document.getElementById('mainSubtitle').textContent = isReadonly
    ? `正在查看 ${USERS[viewingUser]} 的工作台` : t.subtitle;
  document.getElementById('tabHome').textContent     = '🏠 今日工作台';
  document.getElementById('tabTodo').textContent     = '✅ 待办管理';
  document.getElementById('tabMemo').textContent     = '🌙 备忘记录';
  document.getElementById('tabLog').textContent      = t.tabLog;
  document.getElementById('tabCal').textContent      = t.tabCal;
  document.getElementById('tabSummary').textContent  = '📊 工作总结';
  document.getElementById('tabSettings').textContent = '⚙️ 设置';
  updateLineLabels();
  document.getElementById('btnAdd').textContent      = t.btnAdd;
  document.getElementById('btnClear').textContent    = t.btnClear;
  document.getElementById('btnMemo').textContent     = t.btnMemo;
  document.querySelectorAll('.theme-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.theme === themeName);
  });
  makeBubbles();
  // 王一博主题照片墙
  if (themeName === 'wyb') startWybBackground();
  else stopWybBackground();
  updateStats();

  if (save && !isReadonly) {
    localStorage.setItem('wk_theme_' + myIdentity, themeName);
    cache[myIdentity].theme = themeName;
    await cloudSet(metaDoc(myIdentity,'theme'), { name: themeName });
  }
}


// ── 4.3：专线名称与手机导航 ──
function getLineTargetId() {
  return myIdentity === 'kk' ? 'tiffany' : 'kk';
}
function getLineTargetName() {
  return USERS[getLineTargetId()] || 'Tiffany';
}
function getLineLabel(short = false) {
  return short ? '专线' : `💌 ${getLineTargetName()} 专线`;
}

window.openChatPage = function() {
  const url = new URL('./chat.html', window.location.href);
  url.searchParams.set('v', '2.0');
  window.location.href = url.toString();
};
function updateLineLabels() {
  const tab = document.getElementById('tabChat');
  if (tab) {
    const currentUnread = getChatUnreadCount ? getChatUnreadCount() : 0;
    tab.innerHTML = `${getLineLabel(false)}<span class="chat-unread-badge" id="chatUnreadBadge" hidden>${currentUnread}</span>`;
  }
  const mobileLabel = document.getElementById('mobileLineLabel');
  if (mobileLabel) mobileLabel.textContent = getLineLabel(true);
  const title = document.getElementById('chatTitle');
  if (title) title.textContent = getLineLabel(false);
  if (typeof updateChatUnreadBadge === 'function') updateChatUnreadBadge();
}
function setMobileHomeMode(isHome) {
  document.body.classList.toggle('mobile-subpage-mode', !isHome);
}
function setMobileChatMode(isChat) {
  const active = !!isChat && window.innerWidth <= 640;
  document.body.classList.toggle('mobile-chat-mode', active);
  document.documentElement.classList.toggle('mobile-chat-root', active);
  if (!active) {
    document.body.classList.remove('mobile-chat-focused');
    ['--chat-keyboard-inset','--chat-compose-nudge','--chat-compose-height','--chat-toolbar-bottom','--chat-vvh','--chat-vvtop','--chat-focused-height'].forEach(k => document.documentElement.style.removeProperty(k));
  }
}
function updateMobileNav(activeName) {
  const map = { chat:'chat', todo:'todo', summary:'summary' };
  const key = activeName === 'home' ? 'home' : (map[activeName] || '');
  document.querySelectorAll('.mobile-nav-btn').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.mobileNav === key);
  });
}
window.mobileGoHome = function() {
  closeMobileQuickMenu();
  setMobileHomeMode(true);
  document.body.classList.add('desktop-home-mode');
  updateMobileNav('home');
  renderMobileHome();
  setTimeout(() => {
    window.scrollTo({ top:0, behavior:'smooth' });
  }, 40);
};
window.toggleMobileQuickMenu = function() {
  const overlay = document.getElementById('mobileQuickOverlay');
  const sheet = document.getElementById('mobileQuickSheet');
  const show = !sheet?.classList.contains('show');
  overlay?.classList.toggle('show', show);
  sheet?.classList.toggle('show', show);
  if (sheet) sheet.setAttribute('aria-hidden', show ? 'false' : 'true');
};
window.closeMobileQuickMenu = function() {
  document.getElementById('mobileQuickOverlay')?.classList.remove('show');
  const sheet = document.getElementById('mobileQuickSheet');
  sheet?.classList.remove('show');
  if (sheet) sheet.setAttribute('aria-hidden','true');
};

// ── 标签切换 ──
window.switchTab = function(name) {
  closeMobileQuickMenu();
  if (name === 'home') {
    setMobileHomeMode(true);
    document.body.classList.add('desktop-home-mode');
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tabHome')?.classList.add('active');
    setMobileChatMode(false);
    updateMobileNav('home');
    renderMobileHome();
    closeEmojiPanel();
    setTimeout(() => window.scrollTo({ top:0, behavior:'smooth' }), 40);
    return;
  }
  setMobileHomeMode(false);
  setMobileChatMode(name === 'chat');
  document.body.classList.remove('desktop-home-mode');
  if (isReadonly && name === 'settings') return;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
  const tabBtn = document.querySelector(`.tab[onclick="switchTab('${name}')"]`);
  if (tabBtn) tabBtn.classList.add('active');
  const tabContent = document.getElementById('tab-'+name);
  if (tabContent) tabContent.classList.add('active');
  updateMobileNav(name);
  if (name==='log') renderLog();
  if (name==='cal')  renderCal();
  if (name==='summary') renderWorkSummary(false);
  if (name==='chat') {
    clearChatUnread();
    const titleEl = document.getElementById('chatTitle');
    if (titleEl) titleEl.textContent = getLineLabel(false);
    subscribeChat();
    setTimeout(()=>{
      updateChatViewport();
      const el=document.getElementById('chatMessages');
      el.scrollTop=el.scrollHeight;
    },100);
  } else {
    closeEmojiPanel();
  }
  if (name==='settings') {
    const el = document.getElementById('currentIdentityText');
    if (el) el.textContent = `当前是「${USERS[myIdentity]||myIdentity}」`;
  }
};



// ── 第三阶段：手机端今日首页 ──
function renderMobileHome() {
  const root = document.getElementById('mobileHome');
  if (!root) return;
  const d = get();
  if (!d) return;
  const today = localDate();
  const pending = d.todos.filter(t => !t.done).sort(todoSort);
  const doneToday = d.logs
    .filter(l => l.date === today && !l.isReminder)
    .sort((a,b) => (b.createdAt||0) - (a.createdAt||0));
  const total = pending.length + doneToday.length;
  const progress = total ? Math.round(doneToday.length / total * 100) : 100;

  const dateEl = document.getElementById('mobileTodayDate');
  const progressEl = document.getElementById('mobileProgressPill');
  const pendingEl = document.getElementById('mobilePendingCount');
  const doneEl = document.getElementById('mobileDoneCount');
  const memoEl = document.getElementById('mobileMemoCount');
  if (dateEl) dateEl.textContent = `${fmtDate(today)} · ${USERS[viewingUser] || viewingUser}`;
  if (progressEl) progressEl.textContent = `完成 ${progress}%`;
  if (pendingEl) pendingEl.textContent = pending.length;
  if (doneEl) doneEl.textContent = doneToday.length;
  if (memoEl) memoEl.textContent = d.memos.length;

  const todoList = document.getElementById('mobileTodoList');
  if (todoList) {
    const shown = pending.slice(0, 4);
    todoList.innerHTML = shown.length ? shown.map(t => {
      const p = priMap[t.priority] || priMap.normal;
      const cat = getCategoryInfo(t.category);
      const due = getDueInfo(t.dueDate, false);
      return `<div class="mobile-item">
        <button class="mobile-check" type="button" ${isReadonly ? 'disabled' : `onclick="toggleTodo('${t._docId}')"`}>✓</button>
        <div class="mobile-item-body">
          <div class="mobile-item-title">${esc(t.text)}</div>
          <div class="mobile-item-meta">
            <span class="pri-tag ${p.cls}">${p.lbl}</span>
            <span class="cat-tag ${cat.cls}">${cat.lbl}</span>
            ${due ? `<span class="due-tag ${due.cls}">${due.lbl}</span>` : ''}
          </div>
        </div>
      </div>`;
    }).join('') : '<div class="mobile-empty">今天待办清空了，可以喘口气 ☕</div>';
  }

  const doneList = document.getElementById('mobileDoneList');
  if (doneList) {
    const shownDone = doneToday.slice(0, 3);
    doneList.innerHTML = shownDone.length ? shownDone.map(l => {
      const cat = getCategoryInfo(l.category);
      const actions = (!isReadonly && l._docId) ? `<div class="mobile-item-actions">
        <button class="mobile-mini-action" type="button" onclick="event.stopPropagation(); editLog('${l._docId}')">编辑</button>
        <button class="mobile-mini-action danger" type="button" onclick="event.stopPropagation(); deleteLog('${l._docId}')">删</button>
      </div>` : '';
      return `<div class="mobile-item">
        <div class="mobile-done-dot">✓</div>
        <div class="mobile-item-body">
          <div class="mobile-item-title">${esc(l.text)}</div>
          <div class="mobile-item-meta"><span class="cat-tag ${cat.cls}">${cat.lbl}</span></div>
          ${l.completeNote ? `<div class="mobile-done-time">${esc(l.completeNote)}</div>` : `<div class="mobile-done-time">${l.time || ''}</div>`}
        </div>
        ${actions}
      </div>`;
    }).join('') : '<div class="mobile-empty">今天还没有完成记录，先从一件小事开始</div>';
  }
}

window.mobileQuickAddTodo = function() {
  switchTab('todo');
  setTimeout(() => {
    const input = document.getElementById('todoInput');
    if (input && !input.disabled) input.focus();
  }, 80);
};

window.mobileQuickMemo = function() {
  switchTab('memo');
  setTimeout(() => {
    const input = document.getElementById('memoInput');
    if (input && !input.disabled) input.focus();
  }, 80);
};


window.mobileQuickLogDone = async function() {
  if (isReadonly) return;
  const text = prompt('补记完成事项：');
  if (!text || !text.trim()) return;
  const today = localDate();
  const dateInput = prompt('完成日期（格式：YYYY-MM-DD）：', today);
  if (!dateInput) return;
  if (!isValidOptionalDate(dateInput)) { alert('日期格式错误，请使用 YYYY-MM-DD 格式'); return; }
  const categoryInput = prompt('分类代码：daily=日常，material=材料，data=数据，meeting=会议，asset=固定资产，system=系统，temp=临时，other=其他', 'temp');
  const category = catMap[categoryInput] ? categoryInput : 'temp';
  const noteInput = prompt('完成说明（可不填，会进入工作总结素材）：', '');
  const completeNote = noteInput === null ? '' : noteInput.trim();
  const payload = {
    date: dateInput,
    time: fmt(new Date()),
    text: text.trim(),
    priority: 'normal',
    category,
    dueDate: '',
    taskNote: '',
    completeNote,
    todoDocId: null,
    manual: true,
    isReminder: false,
    createdAt: Date.now()
  };
  const logId = await cloudAdd(myIdentity, 'logs', payload);
  currentLogDate = dateInput;
  const d = get();
  if (logId && d && !d.logs.some(l => l._docId === logId)) d.logs.push({ ...payload, _docId: logId });
  renderLog(); renderCal(); updateStats();
  alert('已补记完成 ✓');
};


// ── PWA v2.1：完成记录编辑 / 删除 ──
function refreshAfterLogChange(date) {
  currentLogDate = date || currentLogDate || localDate();
  try { summaryCalSelected = date || summaryCalSelected || currentLogDate; } catch(e) {}
  renderTodos();
  renderLog();
  renderCal();
  updateStats();
  if (typeof renderWorkSummary === 'function') renderWorkSummary(false);
}

window.editLog = async function(id) {
  if (isReadonly) return;
  const d = get();
  const l = d.logs.find(x => x._docId === id);
  if (!l) { alert('没有找到这条完成记录，可能已经同步删除。'); return; }

  const textInput = prompt('修改完成事项：', l.text || '');
  if (textInput === null) return;
  const text = textInput.trim();
  if (!text) { alert('完成事项不能为空'); return; }

  const dateInput = prompt('完成日期（格式：YYYY-MM-DD）：', l.date || localDate());
  if (dateInput === null) return;
  const date = dateInput.trim();
  if (!isValidOptionalDate(date)) { alert('日期格式错误，请使用 YYYY-MM-DD 格式'); return; }

  const priorityInput = prompt('优先级代码：urgent=紧急，important=重要，normal=普通，low=低优', l.priority || 'normal');
  if (priorityInput === null) return;
  const priority = priMap[priorityInput] ? priorityInput : 'normal';

  const categoryInput = prompt('分类代码：daily=日常，material=材料，data=数据，meeting=会议，asset=固定资产，system=系统，temp=临时，other=其他', l.category || 'temp');
  if (categoryInput === null) return;
  const category = catMap[categoryInput] ? categoryInput : 'other';

  const noteInput = prompt('完成说明（可不填，会进入工作总结素材）：', l.completeNote || '');
  if (noteInput === null) return;
  const completeNote = noteInput.trim();

  const { _docId, ...oldData } = l;
  const updated = {
    ...oldData,
    date,
    text,
    priority,
    category,
    completeNote,
    time: l.time || fmt(new Date()),
    updatedAt: Date.now()
  };

  await cloudSet(userDocRef(myIdentity, 'logs', id), updated);
  const idx = d.logs.findIndex(x => x._docId === id);
  if (idx >= 0) d.logs[idx] = { ...updated, _docId:id };

  // 如果这条记录来自“待办完成”，同步回对应待办，避免待办和总结对不上。
  if (l.todoDocId) {
    const t = d.todos.find(x => x._docId === l.todoDocId);
    if (t) {
      const { _docId: todoId, ...todoData } = t;
      const updatedTodo = {
        ...todoData,
        text,
        priority,
        category,
        doneDate: date,
        completeNote,
        updatedAt: Date.now()
      };
      await cloudSet(userDocRef(myIdentity, 'todos', l.todoDocId), updatedTodo);
      const tidx = d.todos.findIndex(x => x._docId === l.todoDocId);
      if (tidx >= 0) d.todos[tidx] = { ...updatedTodo, _docId:l.todoDocId };
    }
  }

  refreshAfterLogChange(date);
  alert('完成记录已更新 ✓');
};

window.deleteLog = async function(id) {
  if (isReadonly) return;
  const d = get();
  const l = d.logs.find(x => x._docId === id);
  if (!l) { alert('没有找到这条完成记录，可能已经同步删除。'); return; }

  if (l.todoDocId) {
    if (!confirm('这条记录来自一个已完成待办。删除完成记录后，对应待办会改回“未完成”。继续吗？')) return;
    const t = d.todos.find(x => x._docId === l.todoDocId);
    if (t) {
      const { _docId: todoId, ...todoData } = t;
      const updatedTodo = {
        ...todoData,
        done:false,
        doneTime:null,
        doneDate:null,
        completeNote:null,
        completedAt:null,
        updatedAt:Date.now()
      };
      await cloudSet(userDocRef(myIdentity, 'todos', l.todoDocId), updatedTodo);
      const tidx = d.todos.findIndex(x => x._docId === l.todoDocId);
      if (tidx >= 0) d.todos[tidx] = { ...updatedTodo, _docId:l.todoDocId };
    }
  } else {
    if (!confirm('删除这条补记完成记录？')) return;
  }

  await cloudDelete(userDocRef(myIdentity, 'logs', id));
  cache[viewingUser].logs = d.logs.filter(x => x._docId !== id);
  refreshAfterLogChange(l.date || localDate());
};


// ── 第四阶段：工作总结生成器 ──
function pad2(n) { return String(n).padStart(2,'0'); }
function dateToLocalString(d) { return `${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())}`; }
function parseLocalDateString(ds) {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(ds || '')) return null;
  const [y,m,d] = ds.split('-').map(Number);
  const dt = new Date(y, m-1, d);
  if (dt.getFullYear()!==y || dt.getMonth()!==m-1 || dt.getDate()!==d) return null;
  return dt;
}
function getWeekRange(base = new Date()) {
  const d = new Date(base.getFullYear(), base.getMonth(), base.getDate());
  const day = d.getDay() || 7;
  const start = new Date(d); start.setDate(d.getDate() - day + 1);
  const end = new Date(start); end.setDate(start.getDate() + 6);
  return { start: dateToLocalString(start), end: dateToLocalString(end), label:'本周' };
}
function getMonthRange(base = new Date()) {
  const start = new Date(base.getFullYear(), base.getMonth(), 1);
  const end = new Date(base.getFullYear(), base.getMonth()+1, 0);
  return { start: dateToLocalString(start), end: dateToLocalString(end), label:'本月' };
}
function getSummaryRange() {
  const type = document.getElementById('summaryRangeType')?.value || 'week';
  if (type === 'month') return getMonthRange();
  if (type === 'custom') {
    const start = document.getElementById('summaryStartDate')?.value || '';
    const end = document.getElementById('summaryEndDate')?.value || '';
    if (!parseLocalDateString(start) || !parseLocalDateString(end) || start > end) return null;
    return { start, end, label:`${fmtDate(start)} 至 ${fmtDate(end)}` };
  }
  return getWeekRange();
}
window.onSummaryRangeChange = function() {
  summaryCalManualMonth = false;
  const type = document.getElementById('summaryRangeType')?.value || 'week';
  const custom = document.getElementById('summaryCustomRange');
  if (custom) custom.classList.toggle('show', type === 'custom');
  if (type === 'custom') {
    const week = getWeekRange();
    const start = document.getElementById('summaryStartDate');
    const end = document.getElementById('summaryEndDate');
    if (start && !start.value) start.value = week.start;
    if (end && !end.value) end.value = week.end;
  }
  renderWorkSummary(false);
};
function summarizeLogs(range) {
  const d = get();
  const logs = (d?.logs || [])
    .filter(l => !l.isReminder && l.date && l.date >= range.start && l.date <= range.end)
    .sort((a,b) => (a.date || '').localeCompare(b.date || '') || (a.createdAt || 0) - (b.createdAt || 0));
  const byCategory = {};
  const byDay = {};
  logs.forEach(l => {
    const category = getCategoryInfo(l.category);
    const key = catMap[l.category] ? l.category : 'other';
    if (!byCategory[key]) byCategory[key] = { key, info:category, items:[] };
    byCategory[key].items.push(l);
    if (!byDay[l.date]) byDay[l.date] = [];
    byDay[l.date].push(l);
  });
  return { logs, byCategory, byDay };
}
function buildSummaryText(range, data) {
  const { logs, byCategory, byDay } = data;
  const userName = USERS[viewingUser] || viewingUser || '我';
  if (!logs.length) {
    return `${range.label}（${range.start} 至 ${range.end}）暂无完成记录。\n\n建议先在待办中完成事项，并填写完成说明，后续这里会自动生成总结草稿。`;
  }
  const categoryRows = Object.values(byCategory).sort((a,b) => b.items.length - a.items.length);
  const categoryText = categoryRows.map(row => `${row.info.lbl}${row.items.length}项`).join('、');
  const noteItems = logs.filter(l => l.completeNote).slice(0, 6);
  const priorityItems = logs.filter(l => ['urgent','important'].includes(l.priority)).slice(0, 6);
  const dailyLines = Object.entries(byDay).sort(([a],[b]) => a.localeCompare(b)).map(([date, items]) => {
    const names = items.slice(0, 4).map(x => x.text).join('；');
    const more = items.length > 4 ? `等${items.length}项` : '';
    return `${fmtDate(date)}：完成${names}${more}`;
  });
  const lines = [];
  lines.push(`${range.label}工作总结（${range.start} 至 ${range.end}）`);
  lines.push('');
  lines.push(`${range.label}，${userName}共完成工作事项${logs.length}项，涉及${categoryRows.length}个工作类别，主要包括${categoryText}。`);
  lines.push('');
  lines.push('一、分类完成情况');
  categoryRows.forEach((row, idx) => {
    const examples = row.items.slice(0, 3).map(x => x.text).join('、');
    lines.push(`${idx+1}. ${row.info.lbl}：完成${row.items.length}项，主要包括${examples}${row.items.length>3?'等事项':''}。`);
  });
  lines.push('');
  lines.push('二、重点事项与完成说明');
  const focus = noteItems.length ? noteItems : priorityItems.length ? priorityItems : logs.slice(0, 5);
  focus.forEach((l, idx) => {
    const cat = getCategoryInfo(l.category).lbl;
    const note = l.completeNote ? `，${l.completeNote}` : '';
    lines.push(`${idx+1}. ${l.text}（${cat}）${note}。`);
  });
  lines.push('');
  lines.push('三、每日推进情况');
  dailyLines.forEach(line => lines.push(line + '。'));
  lines.push('');
  lines.push('总体来看，本阶段工作推进较为有序，能够围绕日常事务、重点任务和临时事项持续跟进落实。后续将继续做好任务记录、过程跟进和结果复盘，提升工作积累和总结效率。');
  return lines.join('\n');
}
window.renderWorkSummary = function(showAlert = false) {
  const panel = document.getElementById('tab-summary');
  if (!panel) return;
  const range = getSummaryRange();
  const textEl = document.getElementById('summaryText');
  const categoryList = document.getElementById('summaryCategoryList');
  const dailyList = document.getElementById('summaryDailyList');
  const totalEl = document.getElementById('summaryTotalCount');
  const catCountEl = document.getElementById('summaryCategoryCount');
  const daysEl = document.getElementById('summaryWorkDays');
  const noteEl = document.getElementById('summaryNoteCount');
  const labelEl = document.getElementById('summaryRangeLabel');
  if (!range) {
    if (showAlert) alert('自定义日期范围不正确，请检查开始日期和结束日期。');
    if (textEl) textEl.value = '日期范围不正确，请重新选择。';
    return;
  }
  const data = summarizeLogs(range);
  const categories = Object.values(data.byCategory).sort((a,b) => b.items.length - a.items.length);
  const days = Object.entries(data.byDay).sort(([a],[b]) => b.localeCompare(a));
  if (totalEl) totalEl.textContent = data.logs.length;
  if (catCountEl) catCountEl.textContent = categories.length;
  if (daysEl) daysEl.textContent = days.length;
  if (noteEl) noteEl.textContent = data.logs.filter(l => l.completeNote).length;
  if (labelEl) labelEl.textContent = `${range.label} · ${fmtDate(range.start)} 至 ${fmtDate(range.end)}`;
  if (categoryList) {
    categoryList.innerHTML = categories.length ? categories.map(row => `
      <div class="summary-cat-row">
        <div class="summary-cat-left"><span class="cat-tag ${row.info.cls}">${row.info.lbl}</span></div>
        <div class="summary-cat-count">${row.items.length} 项</div>
      </div>`).join('') : '<div class="summary-empty">这个范围内还没有分类数据</div>';
  }
  if (dailyList) {
    dailyList.innerHTML = days.length ? days.map(([date, items]) => `
      <div class="summary-day-card">
        <div class="summary-day-title">${fmtDate(date)} · ${items.length} 项</div>
        <ol class="summary-day-items">
          ${items.map(l => {
            const cat = getCategoryInfo(l.category);
            const note = l.completeNote ? `<span class="summary-note-inline"> — ${esc(l.completeNote)}</span>` : '';
            const actions = (!isReadonly && l._docId) ? `<button class="summary-log-action" type="button" onclick="editLog('${l._docId}')">编辑</button><button class="summary-log-action danger" type="button" onclick="deleteLog('${l._docId}')">删</button>` : '';
            return `<li>${esc(l.text)} <span class="cat-tag ${cat.cls}">${cat.lbl}</span>${note}${actions}</li>`;
          }).join('')}
        </ol>
      </div>`).join('') : '<div class="summary-empty">这个范围内还没有完成记录</div>';
  }
  if (textEl) textEl.value = buildSummaryText(range, data);
  renderSummaryCalendar(range);
};
window.copySummaryText = async function() {
  const textEl = document.getElementById('summaryText');
  if (!textEl) return;
  const value = textEl.value || '';
  if (!value.trim()) { alert('还没有可复制的总结内容'); return; }
  try {
    await navigator.clipboard.writeText(value);
    alert('已复制工作总结 ✓');
  } catch(e) {
    textEl.removeAttribute('readonly');
    textEl.focus();
    textEl.select();
    document.execCommand('copy');
    textEl.setAttribute('readonly','readonly');
    alert('已尝试复制，如未成功可手动全选复制');
  }
};


// ── 第四阶段补丁：总结页记录日历 ──
let summaryCalYear = new Date().getFullYear();
let summaryCalMonth = new Date().getMonth();
let summaryCalSelected = localDate();
let summaryCalManualMonth = false;

function syncSummaryCalendarToRange(range) {
  if (!range || summaryCalManualMonth) return;
  const start = parseLocalDateString(range.start);
  if (!start) return;
  summaryCalYear = start.getFullYear();
  summaryCalMonth = start.getMonth();
  if (!summaryCalSelected || summaryCalSelected < range.start || summaryCalSelected > range.end) {
    const today = localDate();
    summaryCalSelected = (today >= range.start && today <= range.end) ? today : range.start;
  }
}

function getLogsByDate(date) {
  const d = get();
  return (d?.logs || [])
    .filter(l => !l.isReminder && l.date === date)
    .sort((a,b) => (a.createdAt || 0) - (b.createdAt || 0));
}

window.summaryCalPrev = function() {
  summaryCalManualMonth = true;
  summaryCalMonth--;
  if (summaryCalMonth < 0) { summaryCalMonth = 11; summaryCalYear--; }
  summaryCalSelected = `${summaryCalYear}-${pad2(summaryCalMonth+1)}-01`;
  renderSummaryCalendar();
};

window.summaryCalNext = function() {
  summaryCalManualMonth = true;
  summaryCalMonth++;
  if (summaryCalMonth > 11) { summaryCalMonth = 0; summaryCalYear++; }
  summaryCalSelected = `${summaryCalYear}-${pad2(summaryCalMonth+1)}-01`;
  renderSummaryCalendar();
};

window.summaryCalClick = function(ds) {
  summaryCalSelected = ds;
  renderSummaryCalendar();
};

function renderSummaryCalendar(range = getSummaryRange()) {
  const grid = document.getElementById('summaryCalGrid');
  const title = document.getElementById('summaryCalTitle');
  const detail = document.getElementById('summaryCalDetail');
  const hint = document.getElementById('summaryCalendarHint');
  if (!grid || !title || !detail) return;
  if (range) syncSummaryCalendarToRange(range);

  const d = get();
  const logs = (d?.logs || []).filter(l => !l.isReminder && l.date);
  const counts = {};
  logs.forEach(l => { counts[l.date] = (counts[l.date] || 0) + 1; });

  const heads = ['日','一','二','三','四','五','六'];
  const today = localDate();
  const firstDay = new Date(summaryCalYear, summaryCalMonth, 1).getDay();
  const daysInMonth = new Date(summaryCalYear, summaryCalMonth + 1, 0).getDate();
  const daysInPrev = new Date(summaryCalYear, summaryCalMonth, 0).getDate();
  title.textContent = `${summaryCalYear}年${summaryCalMonth + 1}月记录`;

  let html = heads.map(h => `<div class="summary-calendar-head">${h}</div>`).join('');
  for (let i = firstDay - 1; i >= 0; i--) {
    html += `<div class="summary-calendar-day other-month">${daysInPrev - i}</div>`;
  }
  for (let day = 1; day <= daysInMonth; day++) {
    const ds = `${summaryCalYear}-${pad2(summaryCalMonth + 1)}-${pad2(day)}`;
    const count = counts[ds] || 0;
    let cls = 'summary-calendar-day';
    if (ds === today) cls += ' today';
    if (ds === summaryCalSelected) cls += ' selected';
    if (count) cls += ' has-record';
    html += `<button class="${cls}" type="button" onclick="summaryCalClick('${ds}')"><span>${day}</span>${count ? `<span class="summary-calendar-count">${count}</span>` : ''}</button>`;
  }
  const total = firstDay + daysInMonth;
  const remain = total % 7 === 0 ? 0 : 7 - (total % 7);
  for (let i = 1; i <= remain; i++) html += `<div class="summary-calendar-day other-month">${i}</div>`;
  grid.innerHTML = html;

  const selectedLogs = getLogsByDate(summaryCalSelected);
  if (hint && range) {
    const monthStart = `${summaryCalYear}-${pad2(summaryCalMonth + 1)}-01`;
    const monthEnd = `${summaryCalYear}-${pad2(summaryCalMonth + 1)}-${pad2(daysInMonth)}`;
    const monthRecordDays = new Set(logs.filter(l => l.date >= monthStart && l.date <= monthEnd).map(l => l.date)).size;
    hint.textContent = `${monthRecordDays} 天有记录 · 点日期看明细`;
  }
  detail.innerHTML = `<div class="summary-calendar-detail-title">${fmtDate(summaryCalSelected)}完成记录 · ${selectedLogs.length} 项</div>` +
    (selectedLogs.length ? `<div class="summary-calendar-detail-list">${selectedLogs.map(l => {
      const cat = getCategoryInfo(l.category);
      const p = priMap[l.priority] || priMap.normal;
      const note = l.completeNote ? `<div class="summary-note-inline">${esc(l.completeNote)}</div>` : '';
      return `<div class="summary-calendar-detail-item">
        <div>${esc(l.text)}</div>
        <div class="summary-calendar-detail-meta"><span class="cat-tag ${cat.cls}">${cat.lbl}</span><span class="pri-tag ${p.cls}">${p.lbl}</span>${l.time ? `<span class="summary-note-inline">${l.time}</span>` : ''}</div>
        ${note}
      </div>`;
    }).join('')}</div>` : '<div class="summary-calendar-empty">这天还没有完成记录</div>');
}



// ── 统计 ──
function updateStats() {
  const d = get();
  const memoTab = document.getElementById('tabMemo');
  if (memoTab) memoTab.textContent = `${themes[currentTheme].tabMemo} · ${d.memos.length}`;
  renderDailyOverview();
  renderMobileHome();
  renderWorkSummary(false);
}

function renderDailyOverview() {
  const d = get();
  if (!d) return;
  const today = localDate();
  const done = d.logs
    .filter(l => l.date === today && !l.isReminder)
    .sort((a,b) => (a.createdAt||0) - (b.createdAt||0));
  const allPending = d.todos
    .filter(t => !t.done)
    .sort(todoSort);
  const isCosmic = themeLayouts[currentTheme] === 'achievement';
  const shownDone = currentTheme === 'wyb' ? done.slice(-3) : (isCosmic ? done.slice(-4) : done);
  const pending = allPending.slice(0, currentTheme === 'wyb' ? 3 : (isCosmic ? 4 : 5));
  const doneTitle = document.getElementById('overviewDoneTitle');
  const todoTitle = document.getElementById('overviewTodoTitle');
  const doneCount = document.getElementById('overviewDoneCount');
  const todoCount = document.getElementById('overviewTodoCount');
  const doneList = document.getElementById('overviewDoneList');
  const todoList = document.getElementById('overviewTodoList');
  const orbitLabel = document.getElementById('cosmicOrbitLabel');
  const progressFill = document.getElementById('cosmicProgressFill');
  const progressText = document.getElementById('cosmicProgressText');
  const calendarBtn = document.getElementById('cosmicCalendarBtn');
  if (!doneTitle || !todoTitle || !doneCount || !todoCount || !doneList || !todoList) return;

  const overviewCopy = {
    space: ['今日完成航线', '待办任务舱'],
    dino: ['今日孵化清单', '森林待办'],
    star: ['今日闪耀记录', '待办星轨'],
    cat: ['今日喵完', '待办喵事'],
    wyb: ['今日打卡', '待办燃点']
  };
  const copy = overviewCopy[currentTheme] || ['今日完成', '待办事项'];
  doneTitle.textContent = copy[0];
  todoTitle.textContent = copy[1];
  doneCount.textContent = done.length;
  todoCount.textContent = allPending.length;
  const totalToday = done.length + allPending.length;
  const progress = totalToday ? Math.round(done.length / totalToday * 100) : 100;
  if (progressFill) progressFill.style.width = `${progress}%`;
  if (progressText) progressText.textContent = `${progress}%`;
  if (orbitLabel) orbitLabel.textContent = currentTheme === 'star' ? '今日星轨' : '今日航线';
  if (calendarBtn) calendarBtn.textContent = `${fmtDate(today)} · 查看总结`;
  renderFocusDashboard(d, done, allPending);

  doneList.innerHTML = shownDone.length ? shownDone.map((l,i)=>`
    <div class="overview-item">
      <span class="overview-index">${i+1}</span>
      <span class="overview-text">${esc(l.text)}</span>
      <span class="overview-meta">${l.time||''}</span>
    </div>`).join('') : '<div class="overview-empty">今天还没有完成记录</div>';

  todoList.innerHTML = pending.length ? pending.map((t,i)=>{
    const p = priMap[t.priority] || priMap.normal;
    const cat = getCategoryInfo(t.category);
    const due = getDueInfo(t.dueDate, t.done);
    return `<div class="overview-item">
      <span class="overview-index">${i+1}</span>
      <span class="overview-text"><span class="pri-tag ${p.cls}">${p.lbl}</span><span class="cat-tag ${cat.cls}">${cat.lbl}</span>${due ? `<span class="due-tag ${due.cls}">${due.lbl}</span>` : ''}${esc(t.text)}</span>
    </div>`;
  }).join('') : '<div class="overview-empty">待办清空了，今天很轻松</div>';
}

function renderFocusDashboard(d, done, allPending) {
  const taskText = document.getElementById('focusTaskText');
  const taskMeta = document.getElementById('focusTaskMeta');
  const completeBtn = document.getElementById('focusCompleteBtn');
  const nextBtn = document.getElementById('focusNextBtn');
  const meterFill = document.getElementById('focusMeterFill');
  const doneText = document.getElementById('focusDoneText');
  const pendingText = document.getElementById('focusPendingText');
  const memoEl = document.getElementById('focusMemo');
  const kicker = document.getElementById('focusKicker');
  const rhythmTitle = document.getElementById('focusRhythmTitle');
  if (!taskText || !taskMeta || !completeBtn || !nextBtn || !meterFill || !doneText || !pendingText || !memoEl) return;

  const total = done.length + allPending.length;
  const progress = total ? Math.round(done.length / total * 100) : 100;
  meterFill.style.width = `${progress}%`;
  doneText.textContent = `完成 ${done.length}`;
  pendingText.textContent = `待办 ${allPending.length}`;
  if (kicker) kicker.textContent = currentTheme === 'cat' ? '现在只做这一件' : '今天先收获这一件';
  if (rhythmTitle) rhythmTitle.textContent = currentTheme === 'cat' ? '今日节奏' : '花园进度';

  const latestMemo = [...d.memos].sort((a,b)=>(b.createdAt||0)-(a.createdAt||0))[0];
  memoEl.textContent = latestMemo ? latestMemo.text : '还没有备忘，点这里记一条';

  if (!allPending.length) {
    currentFocusTaskId = null;
    taskText.textContent = currentTheme === 'cat' ? '待办清空了，安心休息一下' : '花园已经整理好啦';
    taskMeta.textContent = `今日完成度 ${progress}%`;
    completeBtn.disabled = true;
    nextBtn.disabled = true;
    return;
  }

  focusTaskOffset = ((focusTaskOffset % allPending.length) + allPending.length) % allPending.length;
  const task = allPending[focusTaskOffset];
  const p = priMap[task.priority] || priMap.normal;
  currentFocusTaskId = task._docId;
  taskText.textContent = task.text;
  const cat = getCategoryInfo(task.category);
  const due = getDueInfo(task.dueDate, task.done);
  taskMeta.innerHTML = `<span class="pri-tag ${p.cls}">${p.lbl}</span><span class="cat-tag ${cat.cls}">${cat.lbl}</span>${due ? `<span class="due-tag ${due.cls}">${due.lbl}</span>` : ''}<span>${focusTaskOffset+1} / ${allPending.length}</span>`;
  completeBtn.disabled = isReadonly;
  nextBtn.disabled = allPending.length < 2;
}

window.nextFocusTask = function() {
  const d = get();
  const activeCount = d.todos.filter(t=>!t.done).length;
  if (activeCount < 2) return;
  focusTaskOffset = (focusTaskOffset + 1) % activeCount;
  renderDailyOverview();
};

window.completeFocusTask = async function() {
  if (isReadonly || !currentFocusTaskId) return;
  await window.toggleTodo(currentFocusTaskId);
  focusTaskOffset = 0;
  renderDailyOverview();
};

// ── 待办 ──
const catMap = {
  daily:{cls:'cat-daily',lbl:'日常事务'},
  material:{cls:'cat-material',lbl:'材料撰写'},
  data:{cls:'cat-data',lbl:'数据统计'},
  meeting:{cls:'cat-meeting',lbl:'会议沟通'},
  asset:{cls:'cat-asset',lbl:'固定资产'},
  system:{cls:'cat-system',lbl:'系统维护'},
  temp:{cls:'cat-temp',lbl:'临时任务'},
  other:{cls:'cat-other',lbl:'其他事项'}
};

function getCategoryInfo(category) {
  return catMap[category] || catMap.other;
}

function isValidOptionalDate(value) {
  if (!value) return true;
  if (!/^\d{4}-\d{2}-\d{2}$/.test(value)) return false;
  const [y,m,d] = value.split('-').map(Number);
  const parsed = new Date(y, m-1, d);
  return parsed.getFullYear()===y && parsed.getMonth()===m-1 && parsed.getDate()===d;
}

function getDueInfo(dueDate, done = false) {
  if (!dueDate) return null;
  const today = localDate();
  if (done) return { cls:'due-done', lbl:`截止 ${fmtDate(dueDate)}` };
  if (dueDate < today) return { cls:'due-overdue', lbl:`逾期 ${fmtDate(dueDate)}` };
  if (dueDate === today) return { cls:'due-today', lbl:'今天截止' };
  return { cls:'', lbl:`截止 ${fmtDate(dueDate)}` };
}

function updateTodoDueDateLabel() {
  const input = document.getElementById('todoDueDate');
  const field = document.getElementById('todoDueDateField');
  const label = document.getElementById('todoDueDateLabel');
  if (!input || !field || !label) return;
  if (input.value) {
    label.textContent = `截止 ${fmtDate(input.value)}`;
    field.classList.add('has-value');
  } else {
    label.textContent = '截止日期';
    field.classList.remove('has-value');
  }
}

function initTodoDueDateControl() {
  const input = document.getElementById('todoDueDate');
  if (!input) return;
  input.addEventListener('input', updateTodoDueDateLabel);
  input.addEventListener('change', updateTodoDueDateLabel);
  updateTodoDueDateLabel();
}

initTodoDueDateControl();

function todoSort(a,b) {
  const ad = a.dueDate || '9999-99-99';
  const bd = b.dueDate || '9999-99-99';
  if (ad !== bd) return ad.localeCompare(bd);
  const ap = priOrder[a.priority] ?? 2;
  const bp = priOrder[b.priority] ?? 2;
  if (ap !== bp) return ap - bp;
  return (a.createdAt||0) - (b.createdAt||0);
}

window.addTodo = async function() {
  if (isReadonly) return;
  const inp  = document.getElementById('todoInput');
  const text = inp.value.trim(); if (!text) return;
  const dueDate = document.getElementById('todoDueDate')?.value || '';
  if (!isValidOptionalDate(dueDate)) { alert('截止日期格式错误，请使用有效日期'); return; }
  inp.value  = '';
  const dueEl = document.getElementById('todoDueDate');
  if (dueEl) dueEl.value = '';
  updateTodoDueDateLabel();
  await cloudAdd(myIdentity, 'todos', {
    text,
    priority: document.getElementById('todoPri').value,
    category: document.getElementById('todoCategory')?.value || 'daily',
    dueDate,
    taskNote: '',
    completeNote: null,
    done: false, doneTime: null, doneDate: null,
    created: fmt(new Date()), createdAt: Date.now(), updatedAt: Date.now()
  });
};

window.toggleTodo = async function(id) {
  if (isReadonly) return;
  const d = get();
  const t = d.todos.find(x => x._docId === id); if (!t) return;
  if (!t.done) {
    const today     = localDate();
    const dateInput = prompt('选择完成日期（格式：YYYY-MM-DD）：', today);
    if (!dateInput) return;
    if (!isValidOptionalDate(dateInput)) { alert('日期格式错误！请使用 YYYY-MM-DD 格式'); return; }
    const noteInput = prompt('完成说明（可不填，以后生成工作总结会用到）：', t.completeNote || '');
    const completeNote = noteInput === null ? '' : noteInput.trim();
    const doneTime = fmt(new Date());
    const { _docId, ...tData } = t;
    await cloudSet(userDocRef(myIdentity,'todos',id), {
      ...tData,
      category: t.category || 'other',
      dueDate: t.dueDate || '',
      taskNote: t.taskNote || '',
      done:true,
      doneTime,
      doneDate:dateInput,
      completeNote,
      completedAt: Date.now(),
      updatedAt: Date.now()
    });
    const logPayload = {
      date:dateInput,
      time:doneTime,
      text:t.text,
      priority:t.priority || 'normal',
      category:t.category || 'other',
      dueDate:t.dueDate || '',
      taskNote:t.taskNote || '',
      completeNote,
      todoDocId:id,
      isReminder:false,
      createdAt:Date.now()
    };
    const logId = await cloudAdd(myIdentity, 'logs', logPayload);
    currentLogDate = dateInput;
    if (logId && !d.logs.some(l => l._docId === logId)) {
      d.logs.push({ ...logPayload, _docId:logId });
    }
    renderLog();
    renderCal();
    updateStats();
  } else {
    const { _docId, ...tData } = t;
    await cloudSet(userDocRef(myIdentity,'todos',id), { ...tData, done:false, doneTime:null, doneDate:null, completeNote:null, completedAt:null, updatedAt:Date.now() });
    const logEntry = d.logs.find(l => l.todoDocId === id && l.date === t.doneDate);
    if (logEntry?._docId) await cloudDelete(userDocRef(myIdentity,'logs', logEntry._docId));
    cache[viewingUser].logs = d.logs.filter(l => l._docId !== logEntry?._docId);
    renderLog();
    renderCal();
    updateStats();
  }
};

window.editTodo = async function(id) {
  if (isReadonly) return;
  const d = get();
  const t = d.todos.find(x => x._docId === id); if (!t) return;
  const text = prompt('修改任务内容：', t.text || '');
  if (text === null) return;
  const cleanText = text.trim();
  if (!cleanText) { alert('任务内容不能为空'); return; }

  const priorityInput = prompt('优先级代码：urgent=紧急，important=重要，normal=普通，low=低优', t.priority || 'normal');
  if (priorityInput === null) return;
  const priority = priMap[priorityInput] ? priorityInput : 'normal';

  const categoryInput = prompt('分类代码：daily=日常，material=材料，data=数据，meeting=会议，asset=固定资产，system=系统，temp=临时，other=其他', t.category || 'daily');
  if (categoryInput === null) return;
  const category = catMap[categoryInput] ? categoryInput : 'other';

  const dueInput = prompt('截止日期（YYYY-MM-DD，可留空）：', t.dueDate || '');
  if (dueInput === null) return;
  const dueDate = dueInput.trim();
  if (!isValidOptionalDate(dueDate)) { alert('截止日期格式错误！请使用 YYYY-MM-DD，或留空'); return; }

  const taskNoteInput = prompt('任务备注（可留空）：', t.taskNote || '');
  if (taskNoteInput === null) return;

  const { _docId, ...tData } = t;
  await cloudSet(userDocRef(myIdentity,'todos',id), {
    ...tData,
    text: cleanText,
    priority,
    category,
    dueDate,
    taskNote: taskNoteInput.trim(),
    updatedAt: Date.now()
  });
};

window.deleteTodo = async function(id) {
  if (isReadonly) return;
  await cloudDelete(userDocRef(myIdentity, 'todos', id));
};

window.clearDone = async function() {
  if (isReadonly) return;
  if (!confirm('清除所有已完成的任务？')) return;
  const d = get();
  await Promise.all(d.todos.filter(x=>x.done).map(t => cloudDelete(userDocRef(myIdentity,'todos',t._docId))));
};

const priMap   = { urgent:{cls:'pri-urgent',lbl:'紧急'}, important:{cls:'pri-important',lbl:'重要'}, normal:{cls:'pri-normal',lbl:'普通'}, low:{cls:'pri-low',lbl:'低优'} };
const priOrder = { urgent:0, important:1, normal:2, low:3 };

function renderTodos() {
  const d      = get();
  const list   = document.getElementById('todoList');
  const active = d.todos.filter(x=>!x.done).sort(todoSort);
  const done   = d.todos.filter(x=>x.done).sort((a,b)=>(b.completedAt||b.createdAt||0)-(a.completedAt||a.createdAt||0));
  let html = '';
  if (active.length) { html += '<div class="section-lbl">📌 进行中</div>'; active.forEach(t=>html+=todoHTML(t)); }
  if (done.length)   { html += '<div class="section-lbl">✅ 已完成</div>';   done.forEach(t=>html+=todoHTML(t)); }
  if (!active.length && !done.length)
    html = '<div class="empty"><div class="empty-icon">'+themes[currentTheme].icons[0]+'</div><p>暂无待办，轻松一下吧！</p></div>';
  list.innerHTML = html;
}

function todoHTML(t) {
  const p        = priMap[t.priority] || priMap.normal;
  const cat      = getCategoryInfo(t.category);
  const due      = getDueInfo(t.dueDate, t.done);
  const chkClass = isReadonly ? 'chkbox readonly-chk' + (t.done?' on':'') : 'chkbox'+(t.done?' on':'');
  const onClick  = isReadonly ? '' : `onclick="toggleTodo('${t._docId}')"`;
  const editBtn  = isReadonly ? '' : `<button class="edit-btn" title="编辑任务" onclick="editTodo('${t._docId}')">✎</button>`;
  const delBtn   = isReadonly ? '' : `<button class="del-btn" onclick="deleteTodo('${t._docId}')">×</button>`;
  const noteMeta = t.taskNote ? `<span class="note-tag">备注：${esc(t.taskNote)}</span>` : '';
  const completeMeta = t.completeNote ? `<span class="note-tag">完成：${esc(t.completeNote)}</span>` : '';
  return `<div class="todo-item${t.done?' done':''}">
    <div class="${chkClass}" ${onClick}>${t.done?'✓':''}</div>
    <div class="todo-body">
      <div class="todo-title-row">
        <span class="pri-tag ${p.cls}">${p.lbl}</span>
        <span class="todo-text">${esc(t.text)}</span>
      </div>
      <div class="todo-meta-row">
        <span class="cat-tag ${cat.cls}">${cat.lbl}</span>
        ${due ? `<span class="due-tag ${due.cls}">${due.lbl}</span>` : ''}
        ${noteMeta}
        ${completeMeta}
      </div>
    </div>
    <span class="todo-time">${t.done ? t.doneTime||'' : t.created}</span>
    ${editBtn}
    ${delBtn}
  </div>`;
}

// ── 备忘 ──
window.addMemo = async function() {
  if (isReadonly) return;
  const inp  = document.getElementById('memoInput');
  const text = inp.value.trim(); if (!text) return;
  inp.value  = '';
  await cloudAdd(myIdentity, 'memos', { text, created:fmtFull(new Date()), createdAt:Date.now() });
};

window.deleteMemo = async function(id) {
  if (isReadonly) return;
  await cloudDelete(userDocRef(myIdentity, 'memos', id));
};

function renderMemos() {
  const d  = get();
  const el = document.getElementById('memoList');
  const t  = themes[currentTheme];
  if (!d.memos.length) {
    el.innerHTML='<div class="empty"><div class="empty-icon">'+t.icons[1]+'</div><p>还没有备忘，想到什么记下来吧！</p></div>'; return;
  }
  el.innerHTML = [...d.memos].reverse().map((m,i)=>`
    <div class="memo-item">
      <span class="memo-icon">${t.icons[i%t.icons.length]}</span>
      <span class="memo-text">${esc(m.text)}</span>
      <span class="memo-time">${m.created}</span>
      ${isReadonly ? '' : `<button class="memo-del" onclick="deleteMemo('${m._docId}')">×</button>`}
    </div>`).join('');
}

// ── 日志 ──
// ── 日志 ──
let currentLogDate = null; // 用 JS 变量记录当前选中日期，不依赖隐藏元素的 select.value

const logDateSelect = document.getElementById('logDate');
if (logDateSelect) {
  logDateSelect.addEventListener('change', e => {
    currentLogDate = e.target.value;
    renderLog();
    renderCal();
  });
}

function renderLog() {
  const d     = get();
  const today = localDate();
  const sel   = document.getElementById('logDate');

  // 收集有日志的日期
  const logDates = [...new Set(d.logs.map(l=>l.date))].sort().reverse();
  if (!logDates.includes(today)) logDates.unshift(today);

  // 重建选项
  sel.innerHTML = logDates.map(dt=>`<option value="${dt}">${fmtDate(dt)}</option>`).join('');

  // 用 JS 变量而不是 sel.value 来确定选中日期
  const mostRecent = [...new Set(d.logs.filter(l=>!l.isReminder).map(l=>l.date))].sort().reverse()[0];
  if (!currentLogDate || !logDates.includes(currentLogDate)) {
    currentLogDate = mostRecent || today;
  }
  sel.value = currentLogDate;

  const chosen        = currentLogDate;
  const logs          = d.logs.filter(l=>l.date===chosen && !l.isReminder);
  const reminderEntry = d.logs.find(l=>l.date===chosen && l.isReminder);
  const el  = document.getElementById('logList');
  const t   = themes[currentTheme];
  if (!logs.length && !reminderEntry) {
    el.innerHTML='<div class="empty"><div class="empty-icon">'+t.icons[2]+'</div><p>这天还没有完成任何任务</p></div>'; return;
  }
  let html = '';
  if (!logs.length) {
    html = '<div class="empty" style="padding:20px"><div class="empty-icon">'+t.icons[2]+'</div><p>这天还没有完成任何任务</p></div>';
  } else {
    html = logs.map((l,i)=>{
      const p = priMap[l.priority]||priMap.normal;
      const cat = getCategoryInfo(l.category);
      const due = getDueInfo(l.dueDate, true);
      const note = l.completeNote ? `<div class="log-note">完成说明：${esc(l.completeNote)}</div>` : '';
      const actions = (!isReadonly && l._docId) ? `<div class="log-actions">
        <button class="log-action-btn" type="button" onclick="editLog('${l._docId}')">编辑</button>
        <button class="log-action-btn danger" type="button" onclick="deleteLog('${l._docId}')">删除</button>
      </div>` : '';
      return `<div class="log-item">
        <span class="log-num">${i+1}.</span>
        <span class="pri-tag ${p.cls}" style="flex-shrink:0">${p.lbl}</span>
        <div class="log-text-wrap">
          <div class="log-text">${esc(l.text)}</div>
          <div class="log-detail"><span class="cat-tag ${cat.cls}">${cat.lbl}</span>${due ? `<span class="due-tag ${due.cls}">${due.lbl}</span>` : ''}</div>
          ${note}
        </div>
        <span class="log-time">${l.time}</span>
        ${actions}
      </div>`;
    }).join('');
  }
  if (reminderEntry) {
    html += `<div class="log-item" style="opacity:0.5;font-style:italic;border-top:1px dashed #e5e7eb;margin-top:4px;padding-top:8px">
      <span class="log-num">⏰</span>
      <span class="log-text" style="font-size:12px;color:#9ca3af">${esc(reminderEntry.text)}</span>
      <span class="log-time">${reminderEntry.time}</span>
    </div>`;
  }
  el.innerHTML = html;
}

// ── 日历 ──
let calYear     = new Date().getFullYear();
let calMonth    = new Date().getMonth();
let calSelected = null;

window.calPrev = function() { calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCal(); };
window.calNext = function() { calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCal(); };

function renderCal() {
  const d         = get();
  const t         = themes[currentTheme];
  const doneDates = new Set(d.logs.filter(l=>!l.isReminder).map(l=>l.date));
  const heads     = ['日','一','二','三','四','五','六'];
  const today     = localDate();
  const firstDay  = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  const daysInPrev  = new Date(calYear, calMonth, 0).getDate();
  document.getElementById('calTitle').textContent = `${calYear}年${calMonth+1}月 ✨`;
  let html = heads.map(h=>`<div class="cal-head">${h}</div>`).join('');
  for (let i=firstDay-1; i>=0; i--) html+=`<div class="cal-day other-month">${daysInPrev-i}</div>`;
  for (let day=1; day<=daysInMonth; day++) {
    const ds      = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
    const isToday = ds===today;
    const hasDone = doneDates.has(ds);
    let cls = 'cal-day';
    if (isToday) cls+=' today'; else if (ds===calSelected) cls+=' selected';
    if (hasDone) cls+=' has-done';
    const star = hasDone ? `<span class="star">${t.calStar}</span>` : '';
    html+=`<div class="${cls}" data-date="${ds}" onclick="calClick('${ds}')">${day}${star}</div>`;
  }
  const total  = firstDay+daysInMonth;
  const remain = total%7===0 ? 0 : 7-(total%7);
  for (let i=1; i<=remain; i++) html+=`<div class="cal-day other-month">${i}</div>`;
  document.getElementById('calGrid').innerHTML = html;
  renderCalDetail(calSelected || today);
}

window.calClick = function(ds) {
  calSelected = ds;
  document.querySelectorAll('.cal-day').forEach(el => {
    el.classList.remove('selected');
    if (el.dataset.date===ds && !el.classList.contains('today')) el.classList.add('selected');
  });
  renderCalDetail(ds);
};

function renderCalDetail(ds) {
  const d         = get();
  const t         = themes[currentTheme];
  const logs      = d.logs.filter(l=>l.date===ds && !l.isReminder);
  const el        = document.getElementById('calDetail');
  const today     = localDate();
  const dateLabel = ds===today ? '今天' : fmtDate(ds);
  el.innerHTML = `<div class="cal-detail-title">🌌 ${dateLabel} 完成的任务</div>` +
    (logs.length ? logs.map((l,i)=>{
      const cat = getCategoryInfo(l.category);
      const note = l.completeNote ? `<span class="cal-note">${esc(l.completeNote)}</span>` : '';
      const actions = (!isReadonly && l._docId) ? `<button class="summary-log-action" type="button" onclick="editLog('${l._docId}')">编辑</button>` : '';
      return `<div class="cal-log-item">
        <span class="dot">${t.icons[i%t.icons.length]}</span>
        <span class="txt"><span class="cat-tag ${cat.cls}" style="padding:1px 5px;font-size:8px;margin-right:3px">${cat.lbl}</span>${esc(l.text)}${note}</span>
        <span class="tm">${l.time}</span>${actions}
      </div>`;
    }).join('')
    : '<div style="font-size:13px;color:#c4b5fd;padding:8px 4px">这天还没有完成的任务 🌱</div>');
}


// ── 数据备份 / 恢复（第一阶段）──
function setBackupStatus(msg, type = '') {
  const el = document.getElementById('backupStatus');
  if (!el) return;
  el.textContent = msg;
  el.className = 'backup-status' + (type ? ' ' + type : '');
}

function setSyncMessage(msg, online = null) {
  const el = document.getElementById('syncStatusText');
  if (!el) return;
  el.textContent = '同步状态：' + msg;
  el.className = 'sync-status-card' + (online === true ? ' ok' : online === false ? ' err' : '');
}

function cloneForBackup(value) {
  return JSON.parse(JSON.stringify(value || null));
}

function buildBackupPayload(userId) {
  const d = cache[userId];
  return {
    type: 'wk-dashboard-backup',
    version: 2,
    app: '工作小助手 KK & Tiffany',
    exportedAt: new Date().toISOString(),
    exportedBy: userId,
    exportedByName: USERS[userId] || userId,
    data: {
      todos: cloneForBackup(d.todos || []),
      memos: cloneForBackup(d.memos || []),
      logs: cloneForBackup(d.logs || []),
      settings: cloneForBackup(d.settings || { enabled:true, hour:17, min:30 }),
      theme: d.theme || 'space'
    }
  };
}

function safeFileDate() {
  const d = new Date();
  return `${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}_${String(d.getHours()).padStart(2,'0')}${String(d.getMinutes()).padStart(2,'0')}`;
}

function downloadTextFile(filename, content, mime = 'application/json') {
  const blob = new Blob([content], { type: `${mime};charset=utf-8` });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}

window.exportMyData = function() {
  if (isReadonly) return;
  if (!myIdentity || !cache[myIdentity]) {
    setBackupStatus('导出失败：还没有识别当前身份', 'err');
    return;
  }
  const payload = buildBackupPayload(myIdentity);
  const filename = `工作小助手_${USERS[myIdentity] || myIdentity}_备份_${safeFileDate()}.json`;
  downloadTextFile(filename, JSON.stringify(payload, null, 2));
  setBackupStatus(`已导出备份：${filename}`, 'ok');
};

window.chooseImportFile = function() {
  if (isReadonly) return;
  const input = document.getElementById('backupFileInput');
  if (!input) return;
  input.value = '';
  input.click();
};

function cleanDocData(item) {
  const data = { ...(item || {}) };
  delete data._docId;
  delete data.id;
  return data;
}

function normalizeBackupPayload(payload) {
  const data = payload?.data || payload;
  if (!data || typeof data !== 'object') throw new Error('备份文件格式不正确');
  return {
    todos: Array.isArray(data.todos) ? data.todos : [],
    memos: Array.isArray(data.memos) ? data.memos : [],
    logs: Array.isArray(data.logs) ? data.logs : [],
    settings: data.settings && typeof data.settings === 'object' ? data.settings : { enabled:true, hour:17, min:30 },
    theme: typeof data.theme === 'string' ? data.theme : 'space'
  };
}

async function restoreCollection(userId, col, items) {
  const d = cache[userId];
  const existing = Array.isArray(d[col]) ? d[col] : [];
  await Promise.all(existing.map(x => x._docId ? cloudDelete(userDocRef(userId, col, x._docId)) : Promise.resolve()));
  for (const item of items) {
    const data = cleanDocData(item);
    if (item && item._docId) await cloudSet(userDocRef(userId, col, item._docId), data);
    else await cloudAdd(userId, col, data);
  }
}

async function importBackupPayload(payload) {
  if (isReadonly) return;
  const normalized = normalizeBackupPayload(payload);
  const total = normalized.todos.length + normalized.memos.length + normalized.logs.length;
  const backupOwner = payload?.exportedByName || payload?.exportedBy || '未知身份';
  const ok = confirm(
    `确定导入备份并覆盖「${USERS[myIdentity] || myIdentity}」当前数据吗？\n\n` +
    `备份来源：${backupOwner}\n` +
    `待办 ${normalized.todos.length} 条，备忘 ${normalized.memos.length} 条，日志 ${normalized.logs.length} 条。\n\n` +
    `导入会先清空当前身份的待办/备忘/日志，再恢复备份。此操作不影响对方。`
  );
  if (!ok) {
    setBackupStatus('已取消导入', 'warn');
    return;
  }
  setBackupStatus('正在导入备份，请不要关闭页面...', 'warn');
  try {
    await restoreCollection(myIdentity, 'todos', normalized.todos);
    await restoreCollection(myIdentity, 'memos', normalized.memos);
    await restoreCollection(myIdentity, 'logs', normalized.logs);
    cache[myIdentity].settings = normalized.settings;
    cache[myIdentity].theme = normalized.theme;
    await cloudSet(metaDoc(myIdentity,'settings'), normalized.settings);
    await cloudSet(metaDoc(myIdentity,'theme'), { name: normalized.theme });
    localStorage.removeItem('wk_rem_fired_' + myIdentity);
    lastRemKey = null;
    currentLogDate = null;
    applyTheme(normalized.theme, false);
    refreshAll();
    setBackupStatus(`导入完成：已恢复 ${total} 条记录`, 'ok');
    alert('备份导入完成 ✓');
  } catch(e) {
    console.error('导入备份失败', e);
    setBackupStatus('导入失败：' + (e.message || '请检查备份文件和网络'), 'err');
    alert('导入失败，请检查备份文件和网络');
  }
}

function bindBackupImportInput() {
  const input = document.getElementById('backupFileInput');
  if (!input || input.dataset.bound === '1') return;
  input.dataset.bound = '1';
  input.addEventListener('change', e => {
    const file = e.target.files?.[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = async () => {
      try {
        const payload = JSON.parse(String(reader.result || '{}'));
        await importBackupPayload(payload);
      } catch(err) {
        console.error('读取备份失败', err);
        setBackupStatus('读取失败：请选择有效的 JSON 备份文件', 'err');
        alert('读取失败：请选择有效的 JSON 备份文件');
      }
    };
    reader.onerror = () => {
      setBackupStatus('读取失败：浏览器无法读取这个文件', 'err');
    };
    reader.readAsText(file, 'utf-8');
  });
}

// ── 设置 ──
function initSettings() {
  const d   = get();
  const s   = d.settings || {};
  const hSel = document.getElementById('remHour');
  const mSel = document.getElementById('remMin');
  hSel.innerHTML=''; mSel.innerHTML='';
  for (let i=0;i<24;i++) hSel.innerHTML+=`<option value="${i}">${String(i).padStart(2,'0')}</option>`;
  for (let i=0;i<60;i++) mSel.innerHTML+=`<option value="${i}">${String(i).padStart(2,'0')}</option>`;
  hSel.value = s.hour ?? 17;
  mSel.value = s.min  ?? 30;
  document.getElementById('remEnabled').checked = s.enabled !== false;
}

window.switchIdentity = function() {
  const current = USERS[myIdentity] || myIdentity;
  if (!confirm(`当前身份是「${current}」，确定要切换吗？`)) return;
  localStorage.removeItem(LOCAL_IDENTITY_KEY);
  myIdentity = null;
  location.reload();
};

window.saveSettings = async function() {
  if (isReadonly) return;
  const settings = {
    enabled: document.getElementById('remEnabled').checked,
    hour:    parseInt(document.getElementById('remHour').value),
    min:     parseInt(document.getElementById('remMin').value)
  };
  cache[myIdentity].settings = settings;
  await cloudSet(metaDoc(myIdentity,'settings'), settings);
};

window.clearOldTestDataKeepMemos = async function() {
  if (isReadonly) return;
  const d = get();
  const todoCount = d.todos.length;
  const logCount = d.logs.length;
  if (!todoCount && !logCount) {
    alert('当前没有需要清理的待办或工作日志。快速备忘已保留。');
    return;
  }
  const ok = confirm(
    `确定清空 ${USERS[myIdentity]} 的旧测试数据吗？\n\n` +
    `将删除：待办 ${todoCount} 条、工作日志 ${logCount} 条\n` +
    `将保留：快速备忘、专线聊天、主题、提醒设置和身份\n\n` +
    `建议已经导出备份后再继续。`
  );
  if (!ok) return;
  try {
    await Promise.all([
      ...d.todos.map(x => cloudDelete(userDocRef(myIdentity,'todos', x._docId))),
      ...d.logs.map(x  => cloudDelete(userDocRef(myIdentity,'logs',  x._docId)))
    ]);
    cache[myIdentity].todos = [];
    cache[myIdentity].logs = [];
    localStorage.removeItem('wk_rem_fired_' + myIdentity);
    lastRemKey = null;
    setBackupStatus(`已清空旧测试数据：删除待办 ${todoCount} 条、工作日志 ${logCount} 条；快速备忘已保留`, 'ok');
    refreshAll();
    alert('旧测试数据已清空，快速备忘已保留 ✓');
  } catch(e) {
    console.error('清理旧测试数据失败', e);
    setBackupStatus('清理失败：' + (e.message || '请检查网络和权限'), 'err');
    alert('清理失败，请检查网络或 Firebase 权限');
  }
};

window.clearAll = async function() {
  if (isReadonly) return;
  if (!confirm(`确定清除 ${USERS[myIdentity]} 的所有数据？此操作不可恢复！`)) return;
  const d = get();
  // 删除所有 todos、memos、logs
  await Promise.all([
    ...d.todos.map(x => cloudDelete(userDocRef(myIdentity,'todos', x._docId))),
    ...d.memos.map(x => cloudDelete(userDocRef(myIdentity,'memos', x._docId))),
    ...d.logs.map(x  => cloudDelete(userDocRef(myIdentity,'logs',  x._docId)))
  ]);
  // 重置 settings 和 theme
  await cloudSet(metaDoc(myIdentity,'settings'), { enabled:true, hour:17, min:30 });
  await cloudSet(metaDoc(myIdentity,'theme'), { name:'space' });
  localStorage.removeItem('wk_rem_fired_' + myIdentity);
  lastRemKey = null;
  alert('已清除 ✓');
};

// ── 提醒 ──
let lastRemKey = null;

function checkReminderOnLoad() {
  if (isReadonly) return; // 只提醒自己
  const d = get();
  if (!d.settings?.enabled) return;
  const now   = new Date();
  const h     = d.settings.hour ?? 17;
  const m     = d.settings.min  ?? 30;
  const today = localDate(now);
  const firedKey   = 'wk_rem_fired_' + myIdentity;
  const firedDates = JSON.parse(localStorage.getItem(firedKey) || '{}');
  const reminderMin = h*60+m;
  const nowMin      = now.getHours()*60+now.getMinutes();
  if (nowMin >= reminderMin && !firedDates[today]) {
    lastRemKey = `${today}-${h}-${m}`;
    fireReminder(today);
  }
}

async function fireReminder(today) {
  if (isReadonly) return;
  const firedKey   = 'wk_rem_fired_' + myIdentity;
  const firedDates = JSON.parse(localStorage.getItem(firedKey) || '{}');
  firedDates[today] = true;
  const cutoff = localDate(new Date(Date.now()-7*86400000));
  for (const k of Object.keys(firedDates)) { if (k<cutoff) delete firedDates[k]; }
  localStorage.setItem(firedKey, JSON.stringify(firedDates));
  const d      = get();
  const active = d.todos.filter(t=>!t.done);
  const ptxt   = { urgent:'紧急', important:'重要', normal:'普通', low:'低优' };
  let msg;
  if (active.length===0) {
    msg = '🎉 今天所有任务都完成了！\n\n辛苦了，明天继续加油～';
  } else {
    msg = `你有 ${active.length} 件待办未完成：\n\n`;
    active.slice(0,5).forEach((t,i)=>msg+=`${i+1}. [${ptxt[t.priority]||'普通'}] ${t.text}\n`);
    if (active.length>5) msg+=`...还有 ${active.length-5} 件`;
  }
  const now = new Date();
  await cloudAdd(myIdentity, 'logs', {
    date:today, time:fmt(now),
    text:active.length===0 ? '【提醒】今日任务全部完成 🎉' : `【提醒】${active.length} 件待办未完成`,
    priority:'normal', isReminder:true, todoDocId:null, createdAt:Date.now()
  });
  alert(msg);
}

function checkReminder() {
  if (isReadonly) return;
  const d = get();
  if (!d.settings?.enabled) return;
  const now        = new Date();
  const h          = d.settings.hour ?? 17;
  const m          = d.settings.min  ?? 30;
  const today      = localDate(now);
  const currentKey = `${today}-${h}-${m}`;
  if (now.getHours()===h && now.getMinutes()===m && lastRemKey!==currentKey) {
    lastRemKey = currentKey;
    fireReminder(today);
  }
}

// ── 工具函数 ──
function fmt(d)    { return `${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`; }
function fmtFull(d){ return `${d.getMonth()+1}/${d.getDate()} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`; }
// 用本地时区日期，避免 toISOString() 的 UTC 时区问题
function localDate(d) {
  const dt = d || new Date();
  return `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
}
function fmtDate(ds) {
  const today     = localDate();
  const yesterday = localDate(new Date(Date.now()-86400000));
  if (ds===today)     return '今天';
  if (ds===yesterday) return '昨天';
  const [,m,d] = ds.split('-');
  return `${m}月${d}日`;
}
function esc(s) { return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── 背景泡泡 ──
function makeBubbles() {
  const container = document.getElementById('bubbles');
  container.innerHTML='';
  const t     = themes[currentTheme];
  const icons = t.icons;
  const sizes = [18,22,26,20,24,16,28,20,18,22];
  const bubbleCount = currentTheme === 'wyb' ? 15 : 7;
  for (let i=0;i<bubbleCount;i++) {
    const b=document.createElement('div'); b.className='bubble';
    const s=sizes[i%sizes.length];
    b.style.cssText=`width:${s*2}px;height:${s*2}px;left:${Math.random()*100}%;font-size:${s}px;display:flex;align-items:center;justify-content:center;background:transparent;animation-duration:${10+Math.random()*14}s;animation-delay:${Math.random()*10}s;`;
    b.textContent=icons[i%icons.length];
    container.appendChild(b);
  }
}

// ── 聊天 ──
let chatUnsubscribe = null;
let chatMuted = localStorage.getItem('wk_chat_muted') === 'true';
let latestChatTimestamp = 0;
let chatInitialSnapshot = true;

function playBeep() {
  if (chatMuted) return;
  try {
    const ctx = new (window.AudioContext || window.webkitAudioContext)();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.type = 'sine';
    osc.frequency.setValueAtTime(880, ctx.currentTime);
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.15);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.15);
  } catch(e) { /* 浏览器不支持时静默失败 */ }
}

window.toggleMute = function() {
  chatMuted = !chatMuted;
  localStorage.setItem('wk_chat_muted', chatMuted);
  const btn = document.getElementById('muteBtn');
  btn.textContent = chatMuted ? '🔇' : '🔔';
  btn.classList.toggle('muted', chatMuted);
  btn.title = chatMuted ? '已静音，点击开启' : '点击静音';
};

function updateMuteBtn() {
  const btn = document.getElementById('muteBtn');
  if (!btn) return;
  btn.textContent = chatMuted ? '🔇' : '🔔';
  btn.classList.toggle('muted', chatMuted);
  btn.title = chatMuted ? '已静音，点击开启' : '点击静音';
}

function getChatUnreadKey() {
  return `wk_chat_unread_${myIdentity || 'guest'}`;
}

function getChatReadKey() {
  return `wk_chat_read_${myIdentity || 'guest'}`;
}

function getChatUnreadCount() {
  return Number(localStorage.getItem(getChatUnreadKey())) || 0;
}

function updateChatUnreadBadge(count = getChatUnreadCount()) {
  ['chatUnreadBadge','mobileChatUnreadBadge'].forEach(id => {
    const badge = document.getElementById(id);
    if (!badge) return;
    badge.textContent = count > 99 ? '99+' : String(count);
    badge.hidden = count < 1;
  });
}

function addChatUnread(count = 1) {
  const next = getChatUnreadCount() + count;
  localStorage.setItem(getChatUnreadKey(), String(next));
  updateChatUnreadBadge(next);
}

function clearChatUnread() {
  localStorage.removeItem(getChatUnreadKey());
  localStorage.setItem(getChatReadKey(), String(latestChatTimestamp || Date.now()));
  updateChatUnreadBadge(0);
}

function subscribeChat() {
  if (chatUnsubscribe) return;
  const q = collection(db, 'messages');
  chatUnsubscribe = onSnapshot(q, snap => {
    const msgs = [];
    snap.forEach(d => msgs.push({ id:d.id, ...d.data() }));
    msgs.sort((a,b) => (a.ts||0) - (b.ts||0));
    const recent = msgs.slice(-100);
    const previousTimestamp = latestChatTimestamp;
    latestChatTimestamp = msgs.length ? (msgs[msgs.length - 1].ts || 0) : 0;
    const chatOpen = document.getElementById('tab-chat')?.classList.contains('active') && !document.hidden;

    if (chatInitialSnapshot) {
      const lastRead = Number(localStorage.getItem(getChatReadKey())) || 0;
      if (lastRead > 0 && !chatOpen) {
        const unread = msgs.filter(message => message.from !== myIdentity && (message.ts || 0) > lastRead).length;
        localStorage.setItem(getChatUnreadKey(), String(unread));
        updateChatUnreadBadge(unread);
      } else {
        clearChatUnread();
      }
      chatInitialSnapshot = false;
    } else if (latestChatTimestamp > previousTimestamp) {
      const incoming = msgs.filter(message =>
        message.from !== myIdentity &&
        (message.ts || 0) > previousTimestamp
      );
      if (incoming.length) {
        playBeep();
        if (chatOpen) clearChatUnread();
        else addChatUnread(incoming.length);
      }
    }
    renderChat(recent);
    updateMuteBtn();
  }, err => {
    console.error('聊天监听失败', err.code, err.message);
    chatUnsubscribe = null; // 清空，允许重试
  });
}

function renderChat(msgs) {
  const el = document.getElementById('chatMessages');
  if (!msgs.length) {
    el.innerHTML = '<div class="chat-empty">还没有消息，说点什么吧 💬</div>';
    return;
  }
  const wasAtBottom = el.scrollHeight - el.scrollTop - el.clientHeight < 60;
  el.innerHTML = msgs.map(m => {
    const isMe = m.from === myIdentity;
    const name = USERS[m.from] || m.from;
    const emojiClass = isEmojiOnlyMessage(m.text) ? ' emoji-only' : '';
    return `<div class="chat-bubble-wrap ${isMe?'me':'them'}">
      <div class="chat-name">${isMe ? '我' : name}</div>
      <div class="chat-bubble${emojiClass}">${esc(m.text)}</div>
      <div class="chat-time">${m.time||''}</div>
    </div>`;
  }).join('');
  // 如果之前在底部，新消息来了自动滚到底
  if (wasAtBottom) el.scrollTop = el.scrollHeight;
}

window.sendMessage = async function() {
  if (isReadonly) return;
  const inp  = document.getElementById('chatInput');
  const text = inp.value.trim();
  if (!text) return;
  inp.value  = '';
  try {
    await addDoc(collection(db, 'messages'), {
      from: myIdentity,
      text,
      time: fmt(new Date()),
      ts:   Date.now()
    });
  } catch(e) {
    console.error('发送失败', e);
    alert('发送失败，请检查网络');
    inp.value = text;
  }
};

const CHAT_EMOJIS = [
  '😀','😄','😂','🥰','😍','😘','😊','🥳',
  '😭','🥺','😎','🤔','😴','😤','😡','🤭',
  '👍','👏','🙌','🙏','💪','🤝','👌','✌️',
  '❤️','💕','💖','💯','🔥','✨','🎉','🌹',
  '🐱','🐰','⭐','🌙','🚀','🏍️','🎵','💌'
];

function isEmojiOnlyMessage(text) {
  const value = String(text || '').trim();
  if (!value || value.length > 24) return false;
  return /^[\p{Extended_Pictographic}\p{Emoji_Presentation}\uFE0F\u200D\s]+$/u.test(value);
}

function buildEmojiPanel() {
  const panel = document.getElementById('emojiPanel');
  if (!panel || panel.childElementCount) return;
  panel.innerHTML = CHAT_EMOJIS.map(emoji =>
    `<button class="emoji-option" type="button" data-emoji="${emoji}" title="${emoji}">${emoji}</button>`
  ).join('');
  panel.addEventListener('click', e => {
    const btn = e.target.closest('.emoji-option');
    if (!btn) return;
    const inp = document.getElementById('chatInput');
    inp.value += btn.dataset.emoji;
    inp.focus();
  });
}

function closeEmojiPanel() {
  const panel = document.getElementById('emojiPanel');
  if (panel) panel.classList.remove('show');
}

function updateChatViewport() {
  const tab = document.getElementById('tab-chat');
  const wrap = tab?.querySelector('.chat-wrap');
  if (!wrap) return;
  const isChatActive = !!tab?.classList.contains('active');
  if (window.innerWidth > 640 || !isChatActive) {
    wrap.style.removeProperty('--chat-mobile-height');
    setMobileChatMode(false);
    return;
  }

  setMobileChatMode(true);
  const root = document.documentElement;
  const viewport = window.visualViewport;
  const layoutHeight = window.innerHeight || viewport?.height || 640;
  const viewportTop = Math.max(0, Math.floor(viewport?.offsetTop || 0));
  const viewportHeight = Math.floor(viewport?.height || layoutHeight);
  const viewportBottom = viewportTop + viewportHeight;

  root.style.setProperty('--chat-vvh', `${layoutHeight}px`);
  root.style.setProperty('--chat-vvtop', `${viewportTop}px`);
  // 先归零，让浏览器按固定底部摆放；下一帧再根据实际测量微调。
  root.style.setProperty('--chat-keyboard-inset', '0px');
  root.style.setProperty('--chat-compose-nudge', '0px');

  requestAnimationFrame(() => {
    const toolbar = document.querySelector('#tab-chat.active .chat-toolbar');
    const compose = document.getElementById('chatCompose');
    const messages = document.getElementById('chatMessages');
    if (!toolbar || !compose || !messages) return;

    const toolbarBottom = Math.max(52, Math.ceil(toolbar.getBoundingClientRect().bottom));
    const composeHeight = Math.max(62, Math.ceil(compose.getBoundingClientRect().height));
    root.style.setProperty('--chat-toolbar-bottom', `${toolbarBottom}px`);
    root.style.setProperty('--chat-compose-height', `${composeHeight}px`);

    // 核心：不再猜键盘高度，而是测量输入区和 visualViewport 底部的关系。
    // 1) 如果输入区被键盘盖住：增加 bottom inset，把它抬上来。
    // 2) 如果输入区离键盘太远：用 translateY 微调下移，消除大空白。
    const composeRect = compose.getBoundingClientRect();
    let inset = 0;
    let nudge = 0;
    const visibleBottom = viewport ? viewportBottom : layoutHeight;
    if (composeRect.bottom > visibleBottom - 2) {
      inset = Math.ceil(composeRect.bottom - visibleBottom + 2);
    } else if (document.activeElement?.id === 'chatInput' && composeRect.bottom < visibleBottom - 10) {
      nudge = Math.floor(Math.min(120, visibleBottom - composeRect.bottom - 6));
    }
    root.style.setProperty('--chat-keyboard-inset', `${Math.max(0, inset)}px`);
    root.style.setProperty('--chat-compose-nudge', `${Math.max(0, nudge)}px`);

    // 再测一次最终 compose 高度，确保消息区底部不被输入区压住。
    const finalComposeHeight = Math.max(62, Math.ceil(compose.getBoundingClientRect().height));
    root.style.setProperty('--chat-compose-height', `${finalComposeHeight}px`);

    if (messages.scrollHeight - messages.scrollTop - messages.clientHeight < 140) {
      messages.scrollTop = messages.scrollHeight;
    }
  });
}

function settleChatViewport() {
  updateChatViewport();
  setTimeout(updateChatViewport, 160);
  setTimeout(updateChatViewport, 420);
}





